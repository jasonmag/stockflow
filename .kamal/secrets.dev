# Dedicated secrets file for local Kamal development (`bin/kamal-dev ...`).
# Keep this dev-only; do not reuse for shared or production deployments.

RAILS_MASTER_KEY=$(cat config/master.key)
SECRET_KEY_BASE=replace-with-a-stable-local-secret-key-base

POSTGRES_USER=stockflow
POSTGRES_PASSWORD=stockflow_dev_password
DATABASE_URL=postgres://stockflow:stockflow_dev_password@stockflow-dev-db:5432/stockflow_production

<% content_for :title, "Stockflow | Inventory, Purchasing, Delivery, and Cashflow" %>

<%
  core_modules = [
    {
      title: "Inventory Control",
      eyebrow: "Products, locations, stock ledger",
      description: "Track stock in, stock out, transfers, returns, spoilage, and reorder risk across your business."
    },
    {
      title: "Purchasing",
      eyebrow: "Suppliers, receiving, funding source",
      description: "Create purchases, receive verified items into storage, and keep procurement tied to real stock movements."
    },
    {
      title: "Sales Fulfillment",
      eyebrow: "Customers, deliveries, PDF reports",
      description: "Prepare delivery drafts, dispatch from the right location, generate printable reports, and email records fast."
    },
    {
      title: "Cashflow Tracking",
      eyebrow: "Expenses, payables, receivables, collections",
      description: "Monitor what you owe, what you expect to collect, and how daily operations affect net cashflow."
    }
  ]

  workflow_steps = [
    ["Purchase", "Build supplier purchases with item lines, pricing, references, and receiving location."],
    ["Receive", "Confirm physical goods before posting stock-in records to the inventory ledger."],
    ["Move", "Transfer stock between storage and dispatch points or adjust for returns, spoilage, and own use."],
    ["Deliver", "Create customer deliveries, mark completion, and generate shareable PDF delivery reports."],
    ["Collect", "Track receivables, collections, payments, and overdue balances in the same operating system."]
  ]

  outcomes = [
    "One operating view for stock, purchasing, delivery, and finance records",
    "Cleaner handoff between warehouse, dispatch, and accounting workflows",
    "Faster end-of-day reconciliation using consistent transaction history",
    "Better visibility into overdue receivables, urgent payables, and low stock"
  ]
%>

<section class="relative overflow-hidden rounded-[2rem] border border-slate-200/70 bg-[linear-gradient(135deg,#082f49_0%,#0f766e_45%,#ecfeff_100%)] px-6 py-8 text-white shadow-[0_30px_80px_rgba(8,47,73,0.18)] md:px-10 md:py-12">
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(255,255,255,0.2),transparent_32%),radial-gradient(circle_at_80%_20%,rgba(255,255,255,0.14),transparent_20%),radial-gradient(circle_at_bottom_right,rgba(12,74,110,0.35),transparent_30%)]"></div>

  <div class="relative grid gap-8 lg:grid-cols-[minmax(0,1.2fr)_minmax(300px,0.8fr)] lg:items-center">
    <div>
      <span class="inline-flex rounded-full border border-white/20 bg-white/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.28em] text-cyan-50">
        Operations Visibility For Growing Teams
      </span>
      <h1 class="mt-5 max-w-4xl text-4xl font-semibold tracking-tight text-white md:text-5xl">
        Run inventory, purchasing, deliveries, and cashflow from one operational home base.
      </h1>
      <p class="mt-4 max-w-2xl text-base leading-7 text-cyan-50/90 md:text-lg">
        Stockflow is built for small supplier businesses that need tighter control across warehouse activity,
        customer deliveries, receivables, payables, and everyday expense tracking without splitting the work across separate tools.
      </p>

      <div class="mt-8 flex flex-wrap gap-3">
        <%= link_to "User login", login_path, class: "btn border-white/15 bg-white text-slate-900 hover:bg-cyan-50" %>
        <%= link_to "Register", new_registration_path, class: "btn border-white/25 bg-white/10 text-white hover:bg-white/20" %>
        <%= link_to "Admin login", admin_login_path, class: "btn border-white/25 bg-slate-950/25 text-white hover:bg-slate-950/35" %>
      </div>

      <div class="mt-8 grid gap-3 sm:grid-cols-3">
        <div class="rounded-2xl border border-white/15 bg-white/10 px-4 py-4 backdrop-blur-sm">
          <p class="text-xs uppercase tracking-[0.24em] text-cyan-100/70">Workflow</p>
          <p class="mt-2 text-lg font-semibold">Purchase to delivery</p>
        </div>
        <div class="rounded-2xl border border-white/15 bg-white/10 px-4 py-4 backdrop-blur-sm">
          <p class="text-xs uppercase tracking-[0.24em] text-cyan-100/70">Controls</p>
          <p class="mt-2 text-lg font-semibold">Stock, alerts, and approvals</p>
        </div>
        <div class="rounded-2xl border border-white/15 bg-white/10 px-4 py-4 backdrop-blur-sm">
          <p class="text-xs uppercase tracking-[0.24em] text-cyan-100/70">Finance</p>
          <p class="mt-2 text-lg font-semibold">Receivables, payables, and cashflow</p>
        </div>
      </div>
    </div>

    <div class="relative">
      <div class="rounded-[1.75rem] border border-white/20 bg-slate-950/30 p-5 shadow-2xl backdrop-blur-md">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-xs uppercase tracking-[0.24em] text-cyan-100/70">Platform Snapshot</p>
            <h2 class="mt-2 text-2xl font-semibold text-white">Daily operating picture</h2>
          </div>
          <span class="rounded-full bg-emerald-400/20 px-3 py-1 text-xs font-medium text-emerald-100">Live workflow model</span>
        </div>

        <div class="mt-5 grid gap-3 sm:grid-cols-2">
          <div class="rounded-2xl bg-white/10 p-4">
            <p class="text-sm text-cyan-100/75">Inventory movement</p>
            <p class="mt-2 text-3xl font-semibold text-white">In, out, transfer</p>
            <p class="mt-2 text-sm text-cyan-50/85">Built around traceable stock movements per location.</p>
          </div>
          <div class="rounded-2xl bg-white/10 p-4">
            <p class="text-sm text-cyan-100/75">Delivery output</p>
            <p class="mt-2 text-3xl font-semibold text-white">PDF and email</p>
            <p class="mt-2 text-sm text-cyan-50/85">Operational documents stay connected to the transaction record.</p>
          </div>
          <div class="rounded-2xl bg-white/10 p-4">
            <p class="text-sm text-cyan-100/75">Risk tracking</p>
            <p class="mt-2 text-3xl font-semibold text-white">Low stock and overdue</p>
            <p class="mt-2 text-sm text-cyan-50/85">Surface the items and balances that need attention first.</p>
          </div>
          <div class="rounded-2xl bg-gradient-to-br from-amber-300/20 to-rose-300/20 p-4">
            <p class="text-sm text-cyan-100/75">Cashflow view</p>
            <p class="mt-2 text-3xl font-semibold text-white">MTD visibility</p>
            <p class="mt-2 text-sm text-cyan-50/85">Track expenses, collections, payments, and net operating movement.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="mt-8 grid gap-4 lg:grid-cols-[minmax(0,1.1fr)_minmax(0,0.9fr)]">
  <article class="rounded-[1.75rem] border border-slate-200 bg-white/90 p-6 shadow-sm">
    <p class="text-sm font-semibold uppercase tracking-[0.22em] text-cyan-700">What the app covers</p>
    <h2 class="mt-3 text-3xl font-semibold tracking-tight text-slate-900">A full operating loop, not a single-purpose tool.</h2>
    <p class="mt-4 max-w-3xl text-base leading-7 text-slate-600">
      Stockflow connects the main records a small distribution or supplier team works with every day:
      product master data, storage locations, purchases, deliveries, expenses, receivables, payables,
      collections, and payment history.
    </p>

    <div class="mt-6 grid gap-4 md:grid-cols-2">
      <% core_modules.each do |module_card| %>
        <article class="rounded-2xl border border-slate-200 bg-slate-50/80 p-5 transition hover:-translate-y-0.5 hover:border-cyan-300 hover:bg-cyan-50/70">
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-500"><%= module_card[:eyebrow] %></p>
          <h3 class="mt-3 text-xl font-semibold text-slate-900"><%= module_card[:title] %></h3>
          <p class="mt-2 text-sm leading-6 text-slate-600"><%= module_card[:description] %></p>
        </article>
      <% end %>
    </div>
  </article>

  <article class="rounded-[1.75rem] border border-cyan-100 bg-[linear-gradient(180deg,#f0fdfa_0%,#ecfeff_100%)] p-6 shadow-sm">
    <p class="text-sm font-semibold uppercase tracking-[0.22em] text-cyan-700">Business outcomes</p>
    <h2 class="mt-3 text-3xl font-semibold tracking-tight text-slate-900">Designed for control, speed, and auditability.</h2>
    <div class="mt-6 space-y-3">
      <% outcomes.each_with_index do |outcome, index| %>
        <div class="flex items-start gap-3 rounded-2xl border border-cyan-100 bg-white/80 px-4 py-4">
          <span class="mt-0.5 inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-cyan-700 text-sm font-semibold text-white">
            <%= index + 1 %>
          </span>
          <p class="text-sm leading-6 text-slate-700"><%= outcome %></p>
        </div>
      <% end %>
    </div>
    <div class="mt-6 rounded-2xl border border-dashed border-cyan-200 bg-white/70 p-4">
      <p class="text-sm font-medium text-slate-900">Best fit</p>
      <p class="mt-2 text-sm leading-6 text-slate-600">
        Teams that handle physical inventory, customer dispatch, supplier purchases, and repayment or collection follow-up in the same business.
      </p>
    </div>
  </article>
</section>

<section class="mt-8 rounded-[1.75rem] border border-slate-200 bg-slate-950 px-6 py-6 text-white shadow-[0_24px_60px_rgba(15,23,42,0.16)] md:px-8">
  <div class="flex flex-wrap items-end justify-between gap-4">
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.22em] text-cyan-300">How work moves in Stockflow</p>
      <h2 class="mt-3 text-3xl font-semibold tracking-tight">From incoming stock to collected cash.</h2>
    </div>
    <%= link_to "About Stockflow", about_path, class: "btn border-white/10 bg-white/10 text-white hover:bg-white/15" %>
  </div>

  <div class="mt-6 grid gap-4 lg:grid-cols-5">
    <% workflow_steps.each_with_index do |(label, description), index| %>
      <article class="rounded-2xl border border-white/10 bg-white/5 p-5">
        <p class="text-xs font-semibold uppercase tracking-[0.24em] text-cyan-200/75">Step <%= index + 1 %></p>
        <h3 class="mt-3 text-xl font-semibold text-white"><%= label %></h3>
        <p class="mt-2 text-sm leading-6 text-slate-300"><%= description %></p>
      </article>
    <% end %>
  </div>
</section>

<section class="mt-8 grid gap-4 md:grid-cols-[minmax(0,1.15fr)_minmax(280px,0.85fr)]">
  <article class="rounded-[1.75rem] border border-slate-200 bg-white p-6 shadow-sm">
    <p class="text-sm font-semibold uppercase tracking-[0.22em] text-cyan-700">Operational clarity</p>
    <h2 class="mt-3 text-3xl font-semibold tracking-tight text-slate-900">See the system before you enter the dashboard.</h2>
    <p class="mt-4 text-base leading-7 text-slate-600">
      Stockflow gives warehouse, dispatch, and finance teams a shared operational view. From low-stock monitoring
      to overdue balance follow-up, the platform is structured to keep physical movement and money movement aligned.
    </p>
  </article>

  <article class="rounded-[1.75rem] border border-slate-200 bg-slate-50 p-6 shadow-sm">
    <p class="text-sm font-semibold uppercase tracking-[0.22em] text-slate-500">Next action</p>
    <h2 class="mt-3 text-2xl font-semibold tracking-tight text-slate-900">Access the workspace</h2>
    <p class="mt-3 text-sm leading-6 text-slate-600">
      Log in to open the dashboard, or register a new business user account to start managing operations.
    </p>
    <div class="mt-5 flex flex-wrap gap-3">
      <%= link_to "User login", login_path, class: "btn btn-primary" %>
      <%= link_to "Register", new_registration_path, class: "btn btn-secondary" %>
    </div>
  </article>
</section>

<% content_for :title, "Admin Login | Stockflow" %>

<section class="grid gap-6 lg:grid-cols-[minmax(0,0.95fr)_minmax(360px,1.05fr)] lg:items-stretch">
  <article class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm md:p-8">
    <div class="mb-6">
      <p class="text-sm font-semibold uppercase tracking-[0.22em] text-amber-700">Admin Access</p>
      <h1 class="mt-3 text-3xl font-semibold tracking-tight text-slate-900">Enter the system admin console</h1>
      <p class="mt-3 text-sm leading-6 text-slate-600">
        Use a system admin account to approve registrations, create businesses, manage memberships, and impersonate users when support work requires it.
      </p>
    </div>

    <% if alert = flash[:alert] %>
      <p class="flash flash-alert mb-4" id="alert"><%= alert %></p>
    <% end %>

    <% if notice = flash[:notice] %>
      <p class="flash flash-notice mb-4" id="notice"><%= notice %></p>
    <% end %>

    <%= form_with url: session_url, class: "space-y-5" do |form| %>
      <%= form.hidden_field :login_scope, value: "admin" %>

      <div>
        <%= form.label :email_address, "Admin email", class: "field-label" %>
        <%= form.email_field :email_address,
          required: true,
          autofocus: true,
          autocomplete: "username",
          placeholder: "admin@stockflow.local",
          value: params[:email_address],
          class: "field-input" %>
      </div>

      <div>
        <%= form.label :password, "Password", class: "field-label" %>
        <%= form.password_field :password,
          required: true,
          autocomplete: "current-password",
          placeholder: "Enter your password",
          maxlength: 72,
          class: "field-input" %>
      </div>

      <% if recaptcha_enabled? %>
        <div>
          <%= recaptcha_v3(action: "admin_login", turbo: true) %>
        </div>
      <% end %>

      <div class="flex flex-wrap gap-3 pt-2">
        <%= form.submit "Sign in to admin", class: "btn btn-primary min-w-40" %>
        <%= link_to "User login", login_path, class: "btn btn-secondary" %>
      </div>
    <% end %>

    <div class="mt-6 space-y-3 border-t border-slate-200 pt-5 text-sm text-slate-600">
      <p>
        Regular business user?
        <%= link_to "Back to user login", login_path, class: "font-medium text-amber-700 hover:underline" %>
      </p>
      <p>
        Return to the public site:
        <%= link_to "Back to Home", root_path, class: "font-medium text-amber-700 hover:underline" %>
      </p>
    </div>
  </article>

  <article class="relative overflow-hidden rounded-[2rem] border border-slate-200/70 bg-[linear-gradient(145deg,#1f2937_0%,#7c2d12_45%,#fffbeb_100%)] px-6 py-8 text-white shadow-[0_28px_70px_rgba(31,41,55,0.16)] md:px-8 md:py-10">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(255,255,255,0.16),transparent_28%),radial-gradient(circle_at_78%_18%,rgba(255,255,255,0.08),transparent_18%),radial-gradient(circle_at_bottom_right,rgba(120,53,15,0.35),transparent_30%)]"></div>

    <div class="relative">
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-amber-100/80">Restricted Operations</p>
      <h2 class="mt-4 max-w-xl text-4xl font-semibold tracking-tight text-white md:text-5xl">Administrative oversight for registrations and tenant setup.</h2>
      <p class="mt-4 max-w-2xl text-base leading-7 text-amber-50/85">
        This entry point is reserved for platform-level administration. It is separate from the business-user workflow to keep daily operations and system governance clearly divided.
      </p>

      <div class="mt-8 grid gap-4 sm:grid-cols-3">
        <div class="rounded-2xl border border-white/10 bg-white/10 p-4 backdrop-blur-sm">
          <p class="text-xs uppercase tracking-[0.22em] text-amber-100/70">Approve</p>
          <p class="mt-2 text-lg font-semibold">Pending users</p>
        </div>
        <div class="rounded-2xl border border-white/10 bg-white/10 p-4 backdrop-blur-sm">
          <p class="text-xs uppercase tracking-[0.22em] text-amber-100/70">Assign</p>
          <p class="mt-2 text-lg font-semibold">Businesses and roles</p>
        </div>
        <div class="rounded-2xl border border-white/10 bg-white/10 p-4 backdrop-blur-sm">
          <p class="text-xs uppercase tracking-[0.22em] text-amber-100/70">Support</p>
          <p class="mt-2 text-lg font-semibold">Impersonation tools</p>
        </div>
      </div>

      <div class="mt-8 rounded-[1.5rem] border border-white/10 bg-slate-950/25 p-5 backdrop-blur-sm">
        <p class="text-sm font-semibold text-white">Access rule</p>
        <p class="mt-2 text-sm leading-6 text-amber-50/80">
          Non-system-admin accounts are blocked from this route. Use the regular user login screen for business operations accounts.
        </p>
      </div>
    </div>
  </article>
</section>

<% content_for :title, "User Login | Stockflow" %>

<section class="grid gap-6 lg:grid-cols-[minmax(0,1.05fr)_minmax(360px,0.95fr)] lg:items-stretch">
  <article class="relative overflow-hidden rounded-[2rem] border border-slate-200/70 bg-[linear-gradient(145deg,#082f49_0%,#0f766e_48%,#ecfeff_100%)] px-6 py-8 text-white shadow-[0_28px_70px_rgba(8,47,73,0.16)] md:px-8 md:py-10">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(255,255,255,0.2),transparent_30%),radial-gradient(circle_at_80%_20%,rgba(255,255,255,0.12),transparent_18%),radial-gradient(circle_at_bottom_right,rgba(12,74,110,0.35),transparent_32%)]"></div>

    <div class="relative">
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-cyan-100/85">Stockflow Workspace</p>
      <h1 class="mt-4 max-w-xl text-4xl font-semibold tracking-tight text-white md:text-5xl">Sign in to manage the day’s movement.</h1>
      <p class="mt-4 max-w-2xl text-base leading-7 text-cyan-50/90">
        Open the dashboard for inventory, purchases, deliveries, receivables, payables, and operational follow-up from one place.
      </p>

      <div class="mt-8 grid gap-4 sm:grid-cols-3">
        <div class="rounded-2xl border border-white/15 bg-white/10 p-4 backdrop-blur-sm">
          <p class="text-xs uppercase tracking-[0.22em] text-cyan-100/75">Track</p>
          <p class="mt-2 text-lg font-semibold">Low stock</p>
        </div>
        <div class="rounded-2xl border border-white/15 bg-white/10 p-4 backdrop-blur-sm">
          <p class="text-xs uppercase tracking-[0.22em] text-cyan-100/75">Review</p>
          <p class="mt-2 text-lg font-semibold">Overdue balances</p>
        </div>
        <div class="rounded-2xl border border-white/15 bg-white/10 p-4 backdrop-blur-sm">
          <p class="text-xs uppercase tracking-[0.22em] text-cyan-100/75">Dispatch</p>
          <p class="mt-2 text-lg font-semibold">Delivery records</p>
        </div>
      </div>

      <div class="mt-8 rounded-[1.5rem] border border-white/15 bg-slate-950/25 p-5 backdrop-blur-sm">
        <p class="text-sm font-semibold text-white">Regular user access</p>
        <p class="mt-2 text-sm leading-6 text-cyan-50/85">
          Use this sign-in page for approved business users assigned to daily operations. New accounts must be approved by a super admin before access is granted.
        </p>
      </div>
    </div>
  </article>

  <article class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm md:p-8">
    <div class="mb-6">
      <p class="text-sm font-semibold uppercase tracking-[0.22em] text-cyan-700">User Login</p>
      <h2 class="mt-3 text-3xl font-semibold tracking-tight text-slate-900">Access your operations dashboard</h2>
      <p class="mt-3 text-sm leading-6 text-slate-600">
        Sign in with your approved account to continue working on inventory, purchasing, deliveries, and cashflow records.
      </p>
    </div>

    <% if alert = flash[:alert] %>
      <p class="flash flash-alert mb-4" id="alert"><%= alert %></p>
    <% end %>

    <% if notice = flash[:notice] %>
      <p class="flash flash-notice mb-4" id="notice"><%= notice %></p>
    <% end %>

    <%= form_with url: session_url, class: "space-y-5" do |form| %>
      <%= form.hidden_field :login_scope, value: "user" %>

      <div>
        <%= form.label :email_address, "Email address", class: "field-label" %>
        <%= form.email_field :email_address,
          required: true,
          autofocus: true,
          autocomplete: "username",
          placeholder: "name@company.com",
          value: params[:email_address],
          class: "field-input" %>
      </div>

      <div>
        <div class="flex items-center justify-between gap-3">
          <%= form.label :password, "Password", class: "field-label !mb-0" %>
          <%= link_to "Forgot password?", new_password_path, class: "text-sm font-medium text-cyan-700 hover:underline" %>
        </div>
        <%= form.password_field :password,
          required: true,
          autocomplete: "current-password",
          placeholder: "Enter your password",
          maxlength: 72,
          class: "field-input mt-2" %>
      </div>

      <div class="flex flex-wrap gap-3 pt-2">
        <%= form.submit "Sign in", class: "btn btn-primary min-w-32" %>
        <%= link_to "Register", new_registration_path, class: "btn btn-secondary" %>
      </div>
    <% end %>

    <div class="mt-6 space-y-3 border-t border-slate-200 pt-5 text-sm text-slate-600">
      <p>
        Need system administration access?
        <%= link_to "Admin login", admin_login_path, class: "font-medium text-cyan-700 hover:underline" %>
      </p>
      <p>
        Want to explore first?
        <%= link_to "Back to Home", root_path, class: "font-medium text-cyan-700 hover:underline" %>
      </p>
    </div>
  </article>
</section>

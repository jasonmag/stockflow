<div class="mb-6 flex flex-wrap items-end justify-between gap-3">
  <div>
    <h1 class="page-title">Expenses</h1>
    <p class="mt-1 text-sm text-slate-600">Track spending and funding source.</p>
  </div>
  <%= link_to "New Expense", new_expense_path, class: "btn btn-primary" %>
</div>

<div class="mb-6 grid gap-3 md:grid-cols-3">
  <article class="card">
    <p class="kpi-label">Cash MTD</p>
    <p class="kpi-value"><%= money(@cash_expenses_mtd) %></p>
  </article>
  <article class="card">
    <p class="kpi-label">Credit MTD</p>
    <p class="kpi-value"><%= money(@credit_expenses_mtd) %></p>
  </article>
  <article class="card">
    <p class="kpi-label">Total Expenses MTD</p>
    <p class="kpi-value"><%= money(@total_expenses_mtd) %></p>
  </article>
</div>

<section class="card mb-4">
  <%= form_with url: expenses_path, method: :get, class: "grid gap-3 sm:grid-cols-2 lg:grid-cols-5" do |f| %>
    <div>
      <%= f.label :start_date, "Start date", class: "field-label" %>
      <%= f.date_field :start_date, value: params[:start_date], class: "field-input" %>
    </div>
    <div>
      <%= f.label :end_date, "End date", class: "field-label" %>
      <%= f.date_field :end_date, value: params[:end_date], class: "field-input" %>
    </div>
    <div>
      <%= f.label :category_id, "Category", class: "field-label" %>
      <%= f.select :category_id,
        options_from_collection_for_select(current_business.categories.order(:name), :id, :name, params[:category_id]),
        { include_blank: "All categories" },
        class: "field-input" %>
    </div>
    <div>
      <%= f.label :funding_source, "Funding source", class: "field-label" %>
      <%= f.select :funding_source,
        options_for_select([["All sources", ""]] + current_business.purchase_funding_source_options, params[:funding_source]),
        {},
        class: "field-input" %>
    </div>
    <div>
      <%= f.label :payee, "Payee", class: "field-label" %>
      <%= f.text_field :payee, value: params[:payee], placeholder: "Search payee", class: "field-input" %>
    </div>
    <div class="sm:col-span-2 lg:col-span-5 flex items-center gap-2">
      <%= f.submit "Apply filters", class: "btn btn-secondary" %>
      <%= link_to "Reset", expenses_path, class: "btn btn-ghost" %>
    </div>
  <% end %>
</section>

<% if @expenses.any? %>
  <div class="table-wrap">
    <table class="table-base">
      <thead>
        <tr>
          <th>Date</th>
          <th>Payee</th>
          <th>Category</th>
          <th>Funding</th>
          <th>Amount</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @expenses.each do |expense| %>
          <tr>
            <td><%= expense.occurred_on %></td>
            <td class="font-medium text-slate-900"><%= expense.payee %></td>
            <td><%= expense.category&.name || "-" %></td>
            <td><%= expense.funding_source %></td>
            <td class="font-semibold text-slate-900"><%= money(expense.amount_cents, expense.currency) %></td>
            <td class="text-right"><%= link_to "View", expense_path(expense), class: "btn btn-ghost" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <p class="empty-state">No expenses yet. Create one to start tracking spend.</p>
<% end %>

<%= form_with model: expense, multipart: true, class: "card space-y-4", data: { controller: "expense-payment-method expense-payables" } do |f| %>
  <% if expense.errors.any? %>
    <div class="flash flash-alert">
      <p class="font-semibold"><%= pluralize(expense.errors.count, "error") %> prevented this expense from being saved:</p>
      <ul class="mt-2 list-disc pl-5">
        <% expense.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid gap-4 md:grid-cols-2">
    <div>
      <%= f.label :occurred_on, class: "field-label" %>
      <%= f.date_field :occurred_on, class: "field-input" %>
    </div>

    <div>
      <%= f.label :payee, class: "field-label" %>
      <%= f.select :payee,
        options_for_select(@suppliers.map { |supplier| [supplier.name, supplier.name] }, expense.payee),
        { prompt: "Select supplier" },
        class: "field-input",
        data: { expense_payables_target: "payee" } %>
    </div>

    <div>
      <%= f.label :category_id, class: "field-label" %>
      <%= f.select :category_id,
        options_for_select(
          @expense_categories.map { |category| [category.name, category.id, { "data-category-name": category.name }] },
          expense.category_id
        ),
        { prompt: "Select category" },
        class: "field-input",
        data: { expense_payables_target: "category", action: "change->expense-payables#toggle change->expense-payables#syncAmount" } %>
      <div class="mt-2 flex items-center gap-2 text-xs text-slate-600">
        <span>Category not listed?</span>
        <%= link_to "Manage expense categories", categories_path, class: "font-semibold text-slate-900 hover:underline" %>
      </div>
    </div>

    <div>
      <%= f.label :amount_decimal, "Amount", class: "field-label" %>
      <%= f.number_field :amount_decimal, class: "field-input", min: 0.0001, step: "0.0001", placeholder: "0.0000", data: { expense_payables_target: "amount" } %>
    </div>

    <div>
      <%= f.label :currency, class: "field-label" %>
      <%= f.text_field :currency, value: current_business.currency, class: "field-input bg-slate-100", readonly: true %>
    </div>

    <div>
      <%= f.label :funding_source, class: "field-label" %>
      <%= f.select :funding_source,
        options_for_select(
          current_business.purchase_funding_sources.order(:name).map { |source| [source.name, source.name, { "data-source-type": source.source_type }] },
          expense.funding_source
        ),
        { prompt: "Select funding source" },
        class: "field-input",
        data: { expense_payment_method_target: "fundingSource", action: "change->expense-payment-method#sync" } %>
    </div>

    <div>
      <%= f.label :payment_method, class: "field-label" %>
      <%= f.select :payment_method, [], {}, class: "field-input bg-slate-100", data: { expense_payment_method_target: "paymentMethod" } %>
    </div>

    <div>
      <%= f.label :receipt, class: "field-label" %>
      <%= f.file_field :receipt, class: "field-input", accept: "image/*,application/pdf" %>
      <p class="mt-1 text-xs text-slate-600">Upload the receipt, invoice, or proof of payment. When Google Drive storage is connected, Stockflow also syncs this file to the configured Drive folder.</p>
    </div>

    <div class="md:col-span-2">
      <div data-expense-payables-target="payablesSection" class="<%= expense.category&.name == 'Payables' ? '' : 'hidden' %>">
        <%= label_tag "expense_payable_ids", "Covered payables", class: "field-label" %>
        <%= select_tag "expense[payable_ids][]",
          options_for_select(
            @coverable_payables.map { |payable| ["#{payable.payee} - #{money(payable.amount_cents, payable.currency)} due #{payable.due_on}", payable.id, { "data-amount-cents": payable.amount_cents }] },
            expense.payable_ids
          ),
          multiple: true,
          class: "field-input min-h-36",
          data: { expense_payables_target: "payables", action: "change->expense-payables#syncAmount" } %>
        <p class="mt-1 text-xs text-slate-500">Choose the payable records this expense settles. The amount will follow the selected payables.</p>
      </div>
    </div>

    <div class="md:col-span-2">
      <%= f.label :notes, class: "field-label" %>
      <%= f.text_area :notes, class: "field-input", rows: 3 %>
    </div>
  </div>

  <div class="flex flex-wrap gap-2">
    <%= f.submit class: "btn btn-primary" %>
    <%= link_to "Cancel", expenses_path, class: "btn btn-secondary" %>
  </div>
<% end %>

<%= form_with model: expense, class: "card space-y-4" do |f| %>
  <% if expense.errors.any? %>
    <div class="flash flash-alert">
      <p class="font-semibold"><%= pluralize(expense.errors.count, "error") %> prevented this expense from being saved:</p>
      <ul class="mt-2 list-disc pl-5">
        <% expense.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid gap-4 md:grid-cols-2">
    <div>
      <%= f.label :occurred_on, class: "field-label" %>
      <%= f.date_field :occurred_on, class: "field-input" %>
    </div>

    <div>
      <%= f.label :payee, class: "field-label" %>
      <%= f.text_field :payee, class: "field-input" %>
    </div>

    <div>
      <%= f.label :category_id, class: "field-label" %>
      <%= f.collection_select :category_id, current_business.categories.order(:name), :id, :name, { prompt: "Select category" }, class: "field-input" %>
    </div>

    <div>
      <%= f.label :amount_cents, class: "field-label" %>
      <%= f.number_field :amount_cents, class: "field-input", min: 1 %>
    </div>

    <div>
      <%= f.label :currency, class: "field-label" %>
      <%= f.text_field :currency, class: "field-input", placeholder: "PHP" %>
    </div>

    <div>
      <%= f.label :funding_source, class: "field-label" %>
      <%= f.select :funding_source, Expense.funding_sources.keys.map { |value| [value.humanize, value] }, {}, class: "field-input" %>
    </div>

    <div>
      <%= f.label :payment_method, class: "field-label" %>
      <%= f.select :payment_method, Expense.payment_methods.keys.map { |value| [value.humanize, value] }, {}, class: "field-input" %>
    </div>

    <div>
      <%= f.label :receipt, class: "field-label" %>
      <%= f.file_field :receipt, class: "field-input" %>
    </div>

    <div class="md:col-span-2">
      <%= f.label :notes, class: "field-label" %>
      <%= f.text_area :notes, class: "field-input", rows: 3 %>
    </div>
  </div>

  <div class="flex flex-wrap gap-2">
    <%= f.submit class: "btn btn-primary" %>
    <%= link_to "Cancel", expenses_path, class: "btn btn-secondary" %>
  </div>
<% end %>

<div class="mb-6 flex flex-wrap items-end justify-between gap-3">
  <div>
    <h1 class="page-title">Payables</h1>
    <p class="mt-1 text-sm text-slate-600">Track due obligations and mark settled balances.</p>
  </div>
  <%= link_to "New Payable", new_payable_path, class: "btn btn-primary" %>
</div>

<div class="mb-6 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
  <article class="card">
    <p class="kpi-label">Overdue</p>
    <p class="kpi-value"><%= @overdue_payables.count %></p>
  </article>
  <article class="card">
    <p class="kpi-label">Upcoming (30 days)</p>
    <p class="kpi-value"><%= @upcoming_payables.count %></p>
  </article>
  <article class="card">
    <p class="kpi-label">Total Records</p>
    <p class="kpi-value"><%= @payables.count %></p>
  </article>
</div>

<% if @payables.any? %>
  <div class="table-wrap">
    <table class="table-base">
      <thead>
        <tr>
          <th>Payee</th>
          <th>Type</th>
          <th>Due date</th>
          <th>Status</th>
          <th>Amount</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @payables.each do |row| %>
          <tr class="<%= 'bg-rose-50' if row.overdue? %>">
            <td data-label="Payee" class="font-medium text-slate-900"><%= link_to row.payee, payable_path(row), class: "hover:underline" %></td>
            <td data-label="Type"><%= row.payable_type.humanize %></td>
            <td data-label="Due date"><%= row.due_on %></td>
            <td data-label="Status"><%= status_badge(row.status) %></td>
            <td data-label="Amount" class="font-semibold text-slate-900"><%= money(row.amount_cents, row.currency) %></td>
            <td data-label="Actions">
              <div class="flex flex-wrap gap-2">
                <%= link_to "Show", payable_path(row), class: "btn btn-secondary" %>
                <%= link_to "Edit", edit_payable_path(row), class: "btn btn-secondary" %>
                <% unless row.paid? %>
                  <%= button_to "Mark Paid", mark_paid_payable_path(row), method: :patch, class: "btn btn-secondary" %>
                <% else %>
                  <span class="self-center text-xs text-slate-500">Completed</span>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <p class="empty-state">No payables yet. Add one to start tracking due payments.</p>
<% end %>

<%= form_with model: delivery, class: "card space-y-4" do |f| %>
  <% if delivery.errors.any? %>
    <div class="flash flash-alert">
      <p class="font-semibold"><%= pluralize(delivery.errors.count, "error") %> prevented this delivery from being saved:</p>
      <ul class="mt-2 list-disc pl-5">
        <% delivery.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid gap-4 md:grid-cols-2">
    <div>
      <%= f.label :customer_id, class: "field-label" %>
      <%= f.collection_select :customer_id, current_business.customers.order(:name), :id, :name, { prompt: "Select customer" }, class: "field-input" %>
    </div>

    <div>
      <%= f.label :status, class: "field-label" %>
      <%= f.select :status, Delivery.statuses.keys.map { |value| [value.humanize, value] }, {}, class: "field-input" %>
    </div>

    <div>
      <%= f.label :delivered_on, class: "field-label" %>
      <%= f.date_field :delivered_on, class: "field-input" %>
    </div>

    <div>
      <%= f.label :from_location_id, class: "field-label" %>
      <%= f.collection_select :from_location_id, current_business.locations.order(:name), :id, :name, { include_blank: true }, class: "field-input" %>
    </div>

    <div class="md:col-span-2">
      <%= f.label :notes, class: "field-label" %>
      <%= f.text_area :notes, class: "field-input", rows: 3 %>
    </div>
  </div>

  <label class="inline-flex items-center gap-2 text-sm text-slate-700">
    <%= f.check_box :show_prices, class: "h-4 w-4 rounded border-slate-300 text-slate-900 focus:ring-slate-500" %>
    Show prices in delivery report PDF
  </label>

  <section class="rounded-lg border border-slate-200 p-4">
    <h2 class="text-sm font-semibold text-slate-900">Delivery Items</h2>
    <p class="mt-1 text-xs text-slate-600">Add products, quantities, and optional pricing.</p>

    <div class="mt-3 space-y-3">
      <%= f.fields_for :delivery_items do |item| %>
        <div class="grid gap-3 rounded-lg border border-slate-200 p-3 md:grid-cols-3">
          <div>
            <%= item.label :product_id, class: "field-label" %>
            <%= item.collection_select :product_id, current_business.products.order(:name), :id, :name, { prompt: "Select product" }, class: "field-input" %>
          </div>
          <div>
            <%= item.label :quantity, class: "field-label" %>
            <%= item.number_field :quantity, step: 0.01, min: 0.01, class: "field-input" %>
          </div>
          <div>
            <%= item.label :unit_price_cents, class: "field-label" %>
            <%= item.number_field :unit_price_cents, min: 0, class: "field-input" %>
          </div>
        </div>
      <% end %>
    </div>
  </section>

  <div class="flex flex-wrap gap-2">
    <%= f.submit class: "btn btn-primary" %>
    <%= link_to "Cancel", deliveries_path, class: "btn btn-secondary" %>
  </div>
<% end %>

<%= form_with model: delivery, class: "card space-y-4" do |f| %>
  <% if delivery.errors.any? %>
    <div class="flash flash-alert">
      <p class="font-semibold"><%= pluralize(delivery.errors.count, "error") %> prevented this delivery from being saved:</p>
      <ul class="mt-2 list-disc pl-5">
        <% delivery.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid gap-4 md:grid-cols-2">
    <div>
      <label class="field-label">Name</label>
      <%= text_field_tag :delivery_number_preview, delivery.delivery_number_preview, class: "field-input bg-slate-100", readonly: true %>
    </div>

    <div>
      <%= f.label :customer_id, class: "field-label" %>
      <%= f.collection_select :customer_id, current_business.customers.order(:name), :id, :name, { prompt: "Select customer" }, class: "field-input" %>
      <div class="mt-2 flex items-center gap-2 text-xs text-slate-600">
        <span>Customer not listed?</span>
        <%= link_to "Add new customer", new_customer_path(return_to: new_delivery_path), class: "font-semibold text-slate-900 hover:underline" %>
      </div>
    </div>

    <div>
      <%= f.label :delivered_on, class: "field-label" %>
      <%= f.date_field :delivered_on, class: "field-input" %>
    </div>

    <div>
      <%= f.label :from_location_id, class: "field-label" %>
      <%= f.collection_select :from_location_id, current_business.locations.order(:name), :id, :name, { prompt: "Select location" }, class: "field-input" %>
      <div class="mt-2 flex items-center gap-2 text-xs text-slate-600">
        <span>Location not listed?</span>
        <%= link_to "Add new location", new_location_path(return_to: new_delivery_path), class: "font-semibold text-slate-900 hover:underline" %>
      </div>
    </div>

    <div>
      <%= f.label :status, class: "field-label" %>
      <%= f.select :status, Delivery.statuses.keys.map { |value| [value.humanize, value] }, {}, class: "field-input" %>
    </div>

    <div class="flex items-end">
      <label class="inline-flex items-center gap-2 text-sm text-slate-700">
        <%= f.check_box :show_prices, class: "h-4 w-4 rounded border-slate-300 text-slate-900 focus:ring-slate-500" %>
        Show prices in delivery report PDF
      </label>
    </div>

    <div class="md:col-span-2">
      <%= f.label :notes, class: "field-label" %>
      <%= f.text_area :notes, class: "field-input", rows: 3 %>
    </div>
  </div>

  <section class="rounded-lg border border-slate-200 p-4">
    <h2 class="text-sm font-semibold text-slate-900">Delivery Items</h2>
    <p class="mt-1 text-xs text-slate-600">Add at least one item and quantity.</p>

    <div class="mt-3 space-y-3" data-controller="nested-delivery-items" data-action="delivery-items:recalculate->nested-delivery-items#updateOverall" data-nested-delivery-items-currency-value="<%= current_business.currency %>">
      <div class="rounded-lg border border-slate-200">
        <div class="hidden border-b border-slate-200 bg-slate-50 px-3 py-2 text-xs font-semibold uppercase tracking-wide text-slate-600 md:grid md:grid-cols-[minmax(0,2.2fr)_minmax(110px,0.8fr)_minmax(130px,0.9fr)_minmax(130px,0.9fr)_auto] md:gap-3">
          <div>Product</div>
          <div>Quantity</div>
          <div>Unit price</div>
          <div>Sub-total</div>
          <div>Action</div>
        </div>

        <div data-nested-delivery-items-target="list" class="divide-y divide-slate-200 p-3 space-y-3 md:space-y-0">
        <%= f.fields_for :delivery_items do |item| %>
          <%= render "delivery_item_fields", form: item, products: current_business.products.order(:name), currency: current_business.currency %>
        <% end %>
        </div>
      </div>

      <div class="flex justify-end">
        <div class="purchase-items-overall-total">
          <span class="purchase-items-overall-total-label">Total</span>
          <span data-nested-delivery-items-target="overall"><%= money(0, current_business.currency) %></span>
        </div>
      </div>

      <template data-nested-delivery-items-target="template">
        <%= f.fields_for :delivery_items, DeliveryItem.new, child_index: "NEW_RECORD" do |item| %>
          <%= render "delivery_item_fields", form: item, products: current_business.products.order(:name), currency: current_business.currency %>
        <% end %>
      </template>

      <div class="flex flex-wrap gap-2">
        <button type="button" class="btn btn-secondary" data-action="click->nested-delivery-items#add">Add another product</button>
        <%= link_to "Add new inventory variant", new_product_path(return_to: new_delivery_path), class: "btn btn-secondary" %>
      </div>
    </div>
  </section>

  <div class="flex flex-wrap gap-2">
    <%= f.submit class: "btn btn-primary" %>
    <%= button_tag "Preview PDF",
                   type: "submit",
                   class: "btn btn-secondary",
                   formaction: preview_pdf_deliveries_path,
                   formmethod: "get",
                   formtarget: "_blank" %>
    <%= link_to "Cancel", deliveries_path, class: "btn btn-secondary" %>
  </div>
<% end %>

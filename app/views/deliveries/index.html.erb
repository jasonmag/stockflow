<div class="mb-6 flex flex-wrap items-end justify-between gap-3">
  <div>
    <h1 class="page-title">Deliveries</h1>
    <p class="mt-1 text-sm text-slate-600">Manage dispatches, reports, and delivery status.</p>
  </div>
  <%= link_to "New Delivery", new_delivery_path, class: "btn btn-primary" %>
</div>

<section class="card mb-4">
  <%= form_with url: deliveries_path, method: :get, class: "grid gap-3 sm:grid-cols-2 lg:grid-cols-4" do |f| %>
    <div>
      <%= f.label :customer_id, "Customer", class: "field-label" %>
      <%= f.select :customer_id,
        options_from_collection_for_select(current_business.customers.order(:name), :id, :name, params[:customer_id]),
        { include_blank: "All customers" },
        class: "field-input" %>
    </div>
    <div>
      <%= f.label :status, class: "field-label" %>
      <%= f.select :status,
        options_for_select(Delivery.statuses.keys.map { |status| [status.humanize, status] }.prepend(["All statuses", ""]), params[:status]),
        {},
        class: "field-input" %>
    </div>
    <div>
      <%= f.label :start_date, "Start date", class: "field-label" %>
      <%= f.date_field :start_date, value: params[:start_date], class: "field-input" %>
    </div>
    <div>
      <%= f.label :end_date, "End date", class: "field-label" %>
      <%= f.date_field :end_date, value: params[:end_date], class: "field-input" %>
    </div>
    <div class="flex flex-wrap items-center gap-2 sm:col-span-2 lg:col-span-4">
      <%= f.submit "Apply filters", class: "btn btn-secondary" %>
      <%= link_to "Reset", deliveries_path, class: "btn btn-ghost" %>
    </div>
  <% end %>
</section>

<% if @deliveries.any? %>
  <div class="table-wrap">
    <table class="table-base">
      <thead>
        <tr>
          <th>Delivery #</th>
          <th>Date</th>
          <th>Customer</th>
          <th>Status</th>
          <th>PDF</th>
          <th class="text-right">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @deliveries.each do |delivery| %>
          <tr>
            <td data-label="Delivery #" class="font-medium text-slate-900"><%= link_to delivery.delivery_number, delivery_path(delivery), class: "hover:underline" %></td>
            <td data-label="Date"><%= delivery.delivered_on %></td>
            <td data-label="Customer"><%= delivery.customer.name %></td>
            <td data-label="Status"><%= status_badge(delivery.status) %></td>
            <td data-label="PDF">
              <% if delivery.report_pdf_available? %>
                <span class="badge badge-success">Attached</span>
              <% else %>
                <span class="badge badge-neutral">Missing</span>
              <% end %>
            </td>
            <td data-label="Actions">
              <div class="flex flex-wrap justify-end gap-2">
                <%= link_to "View", delivery_path(delivery), class: "btn btn-ghost" %>
                <%= button_to "Generate PDF", generate_pdf_delivery_path(delivery), method: :post, class: "btn btn-secondary" %>
                <% unless delivery.delivered? %>
                  <%= button_to "Mark Delivered", mark_delivered_delivery_path(delivery), method: :patch, class: "btn btn-primary" %>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <p class="empty-state">No deliveries found for the selected filters.</p>
<% end %>

<div class="mb-4">
  <h1 class="page-title">Edit Category</h1>
  <p class="mt-1 text-sm text-slate-600">Rename this category.</p>
</div>

<%= form_with model: @category, class: "card space-y-4" do |f| %>
  <% if @category.errors.any? %>
    <div class="flash flash-alert">
      <p class="font-semibold"><%= pluralize(@category.errors.count, "error") %> prevented this category from being saved:</p>
      <ul class="mt-2 list-disc pl-5">
        <% @category.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name, class: "field-label" %>
    <%= f.text_field :name, class: "field-input" %>
  </div>

  <div class="flex flex-wrap gap-2">
    <%= f.submit "Save", class: "btn btn-primary" %>
    <%= link_to "Back", categories_path, class: "btn btn-secondary" %>
  </div>
<% end %>

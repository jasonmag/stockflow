<div class="mb-6">
  <h1 class="page-title">Categories</h1>
  <p class="mt-1 text-sm text-slate-600">Maintain expense categories for cleaner reporting.</p>
</div>

<section class="card mb-4">
  <h2 class="mb-3 text-base font-semibold text-slate-900">New Category</h2>

  <%= form_with model: @category, class: "grid gap-3 sm:grid-cols-[1fr_auto]" do |f| %>
    <div>
      <%= f.label :name, class: "field-label" %>
      <%= f.text_field :name, class: "field-input", placeholder: "Category name" %>
    </div>
    <div class="self-end">
      <%= f.submit "Add", class: "btn btn-primary" %>
    </div>
  <% end %>
</section>

<% if @categories.any? %>
  <div class="table-wrap">
    <table class="table-base">
      <thead>
        <tr>
          <th>Name</th>
          <th class="text-right">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @categories.each do |category| %>
          <tr>
            <td class="font-medium text-slate-900"><%= category.name %></td>
            <td class="text-right">
              <div class="flex flex-wrap justify-end gap-2">
                <%= link_to "Edit", edit_category_path(category), class: "btn btn-ghost" %>
                <%= button_to "Delete", category_path(category), method: :delete, class: "btn btn-danger", data: { turbo_confirm: "Delete this category?" } %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <p class="empty-state">No categories yet. Add one to classify expenses.</p>
<% end %>

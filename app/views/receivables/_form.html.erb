<%= form_with model: receivable, class: "card space-y-4" do |f| %>
  <% if receivable.errors.any? %>
    <div class="flash flash-alert">
      <p class="font-semibold"><%= pluralize(receivable.errors.count, "error") %> prevented this receivable from being saved:</p>
      <ul class="mt-2 list-disc pl-5">
        <% receivable.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid gap-4 md:grid-cols-2">
    <div>
      <%= f.label :customer_id, class: "field-label" %>
      <%= f.collection_select :customer_id, current_business.customers.order(:name), :id, :name, { prompt: "Select customer" }, class: "field-input" %>
    </div>

    <div>
      <%= f.label :reference, class: "field-label" %>
      <%= f.text_field :reference, class: "field-input", placeholder: "Invoice/DR reference" %>
    </div>

    <div>
      <%= f.label :delivered_on, class: "field-label" %>
      <%= f.date_field :delivered_on, class: "field-input" %>
    </div>

    <div>
      <%= f.label :due_on, class: "field-label" %>
      <%= f.date_field :due_on, class: "field-input" %>
    </div>

    <div>
      <%= f.label :amount_cents, class: "field-label" %>
      <%= f.number_field :amount_cents, class: "field-input", min: 1 %>
    </div>

    <div>
      <%= f.label :currency, class: "field-label" %>
      <%= f.text_field :currency, value: current_business.currency, class: "field-input bg-slate-100", readonly: true %>
    </div>

    <div>
      <%= f.label :status, class: "field-label" %>
      <%= f.select :status, Receivable.statuses.keys.map { |value| [value.humanize, value] }, {}, class: "field-input" %>
    </div>

    <div class="md:col-span-2">
      <%= f.label :notes, class: "field-label" %>
      <%= f.text_area :notes, class: "field-input", rows: 3 %>
    </div>
  </div>

  <div class="flex flex-wrap gap-2">
    <%= f.submit class: "btn btn-primary" %>
    <%= link_to "Cancel", receivables_path, class: "btn btn-secondary" %>
  </div>
<% end %>

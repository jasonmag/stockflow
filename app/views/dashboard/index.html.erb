<h1 class="text-2xl font-semibold mb-4">Dashboard</h1>

<div class="grid md:grid-cols-4 gap-3 mb-6">
  <div class="bg-white rounded border p-3"><p class="text-xs text-slate-500">Expenses MTD</p><p class="font-semibold"><%= money(@expenses_total) %></p></div>
  <div class="bg-white rounded border p-3"><p class="text-xs text-slate-500">Personal Out-of-pocket MTD</p><p class="font-semibold"><%= money(@personal_total) %></p></div>
  <div class="bg-white rounded border p-3"><p class="text-xs text-slate-500">Collections MTD</p><p class="font-semibold"><%= money(@collections_total) %></p></div>
  <div class="bg-white rounded border p-3"><p class="text-xs text-slate-500">Net Cashflow MTD</p><p class="font-semibold"><%= money(@net_cashflow) %></p></div>
</div>

<div class="grid md:grid-cols-2 gap-4">
  <section class="bg-white rounded border p-3">
    <h2 class="font-semibold mb-2">Overdue Payables</h2>
    <% @overdue_payables.each do |row| %><p><%= row.payee %> - <%= row.due_on %></p><% end %>
  </section>
  <section class="bg-white rounded border p-3">
    <h2 class="font-semibold mb-2">Overdue Receivables</h2>
    <% @overdue_receivables.each do |row| %><p><%= row.reference.presence || row.customer.name %> - <%= row.due_on %></p><% end %>
  </section>
</div>

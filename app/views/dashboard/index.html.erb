<div class="mb-6 flex flex-wrap items-end justify-between gap-3">
  <div>
    <h1 class="page-title">Dashboard</h1>
    <p class="mt-1 text-sm text-slate-600">Today: <%= Date.current.to_fs(:long) %></p>
  </div>
  <div class="flex items-center gap-2">
    <%= link_to "New Expense", new_expense_path, class: "btn btn-secondary" %>
    <%= link_to "New Delivery", new_delivery_path, class: "btn btn-primary" %>
  </div>
</div>

<div class="mb-6 grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
  <article class="card">
    <p class="kpi-label">Expenses MTD</p>
    <p class="kpi-value"><%= money(@expenses_total) %></p>
  </article>
  <article class="card">
    <p class="kpi-label">Cash Expenses MTD</p>
    <p class="kpi-value"><%= money(@cash_expenses_total) %></p>
  </article>
  <article class="card">
    <p class="kpi-label">Collections MTD</p>
    <p class="kpi-value"><%= money(@collections_total) %></p>
  </article>
  <article class="card">
    <p class="kpi-label">Net Cashflow MTD</p>
    <p class="kpi-value"><%= money(@net_cashflow) %></p>
  </article>
</div>

<div class="grid gap-4 xl:grid-cols-2">
  <section class="card">
    <div class="mb-3 flex items-center justify-between">
      <h2 class="text-base font-semibold text-slate-900">Urgent Payables</h2>
      <%= link_to "View all", payables_path, class: "text-sm text-blue-700 hover:underline" %>
    </div>
    <% if @overdue_payables.any? %>
      <div class="space-y-2">
        <% @overdue_payables.each do |row| %>
          <div class="flex items-start justify-between gap-3 rounded-lg border border-rose-200 bg-rose-50 px-3 py-2">
            <div>
              <p class="text-sm font-medium text-slate-900"><%= row.payee %></p>
              <p class="text-xs text-slate-600">Due <%= row.due_on.to_fs(:long) %></p>
            </div>
            <div class="text-right">
              <%= status_badge(row.status) %>
              <p class="mt-1 text-sm font-semibold text-slate-900"><%= money(row.amount_cents, row.currency) %></p>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="empty-state">No overdue payables right now.</p>
    <% end %>
  </section>

  <section class="card">
    <div class="mb-3 flex items-center justify-between">
      <h2 class="text-base font-semibold text-slate-900">Urgent Receivables</h2>
      <%= link_to "View all", receivables_path, class: "text-sm text-blue-700 hover:underline" %>
    </div>
    <% if @overdue_receivables.any? %>
      <div class="space-y-2">
        <% @overdue_receivables.each do |row| %>
          <div class="flex items-start justify-between gap-3 rounded-lg border border-amber-200 bg-amber-50 px-3 py-2">
            <div>
              <p class="text-sm font-medium text-slate-900"><%= row.reference.presence || row.customer.name %></p>
              <p class="text-xs text-slate-600">Due <%= row.due_on.to_fs(:long) %></p>
            </div>
            <div class="text-right">
              <%= status_badge(row.status) %>
              <p class="mt-1 text-sm font-semibold text-slate-900"><%= money(row.amount_cents, row.currency) %></p>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="empty-state">No overdue receivables right now.</p>
    <% end %>
  </section>

  <section class="card">
    <div class="mb-3 flex items-center justify-between">
      <h2 class="text-base font-semibold text-slate-900">Low Stock Alerts</h2>
      <%= link_to "Inventory", stock_movements_path, class: "text-sm text-blue-700 hover:underline" %>
    </div>
    <% if @low_stock_products.any? %>
      <ul class="space-y-2">
        <% @low_stock_products.each do |product| %>
          <li class="flex items-center justify-between rounded-lg border border-amber-200 bg-amber-50 px-3 py-2">
            <span class="text-sm font-medium text-slate-900"><%= product.name %></span>
            <span class="badge badge-warning">Low stock</span>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="empty-state">No low-stock alerts.</p>
    <% end %>
  </section>

  <section class="card">
    <div class="mb-3 flex items-center justify-between">
      <h2 class="text-base font-semibold text-slate-900">Deliveries Today</h2>
      <%= link_to "Deliveries", deliveries_path, class: "text-sm text-blue-700 hover:underline" %>
    </div>
    <% if @today_deliveries.any? %>
      <ul class="space-y-2">
        <% @today_deliveries.each do |delivery| %>
          <li class="flex items-center justify-between rounded-lg border border-slate-200 px-3 py-2">
            <span class="text-sm font-medium text-slate-900"><%= link_to delivery.delivery_number, delivery_path(delivery), class: "hover:underline" %></span>
            <%= status_badge(delivery.status) %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="empty-state">No completed deliveries today.</p>
    <% end %>
  </section>
</div>

<div class="mb-6 flex flex-wrap items-end justify-between gap-3">
  <div>
    <h1 class="page-title"><%= @product.name %></h1>
    <p class="mt-1 text-sm text-slate-600">Product details and inventory setup.</p>
  </div>
  <div class="flex flex-wrap gap-2">
    <%= link_to "Edit", edit_product_path(@product), class: "btn btn-primary" %>
    <%= link_to "Back", products_path, class: "btn btn-secondary" %>
  </div>
</div>

<section class="card">
  <dl class="grid gap-4 sm:grid-cols-2">
    <div>
      <dt class="kpi-label">Inventory Type</dt>
      <dd class="mt-1"><%= status_badge(@product.inventory_type) %></dd>
    </div>
    <div>
      <dt class="kpi-label">SKU</dt>
      <dd class="mt-1 text-sm text-slate-900"><%= @product.sku.presence || "-" %></dd>
    </div>
    <div>
      <dt class="kpi-label">Brand</dt>
      <dd class="mt-1 text-sm text-slate-900"><%= @product.brand.presence || "-" %></dd>
    </div>
    <div>
      <dt class="kpi-label">Unit</dt>
      <dd class="mt-1 text-sm text-slate-900"><%= @product.unit %></dd>
    </div>
    <div>
      <dt class="kpi-label">Barcode</dt>
      <dd class="mt-1 text-sm text-slate-900"><%= @product.barcode.presence || "-" %></dd>
    </div>
    <div>
      <dt class="kpi-label">Default Cost</dt>
      <dd class="mt-1 text-sm text-slate-900"><%= @product.base_cost_cents.present? ? money(@product.base_cost_cents) : "-" %></dd>
    </div>
    <div>
      <dt class="kpi-label">Reorder Level</dt>
      <dd class="mt-1 text-sm text-slate-900"><%= @product.reorder_level || "-" %></dd>
    </div>
    <div>
      <dt class="kpi-label">Status</dt>
      <dd class="mt-1"><%= status_badge(@product.active? ? :active : :inactive) %></dd>
    </div>
    <div class="sm:col-span-2">
      <dt class="kpi-label">Description</dt>
      <dd class="mt-1 text-sm text-slate-900"><%= @product.description.presence || "-" %></dd>
    </div>
  </dl>
</section>

<section class="mt-6">
  <div class="mb-4">
    <h2 class="text-xl font-semibold text-slate-900">Price Management</h2>
    <p class="mt-1 text-sm text-slate-600">Maintain separate effective-dated selling and purchase prices for this product.</p>
  </div>

  <div class="grid gap-6 xl:grid-cols-2">
    <section class="overflow-hidden rounded-2xl border border-emerald-200 bg-gradient-to-br from-emerald-50 via-white to-emerald-100/60 shadow-sm">
      <div class="border-b border-emerald-200/80 px-6 py-5">
        <div class="flex items-start justify-between gap-4">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-emerald-700">Selling</p>
            <h3 class="mt-2 text-xl font-semibold text-slate-900">Customer Price Track</h3>
            <p class="mt-1 text-sm text-slate-600">Use this when the outgoing price changes over time.</p>
          </div>
          <div class="rounded-full border border-emerald-300 bg-white/80 px-3 py-1 text-xs font-medium text-emerald-700">
            <%= @product_prices.count %> entries
          </div>
        </div>
      </div>

      <div class="space-y-6 px-6 py-6">
        <div class="grid gap-3 sm:grid-cols-3">
          <div class="rounded-2xl border border-emerald-200 bg-white px-4 py-4 shadow-sm">
            <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Current Price</p>
            <p class="mt-2 text-2xl font-semibold text-slate-900"><%= @current_product_price.present? ? money(@current_product_price.price_cents) : "-" %></p>
          </div>
          <div class="rounded-2xl border border-emerald-200 bg-white px-4 py-4 shadow-sm">
            <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Effective Since</p>
            <p class="mt-2 text-sm font-medium text-slate-900"><%= @current_product_price&.effective_on&.to_fs(:long) || "-" %></p>
          </div>
          <div class="rounded-2xl border border-emerald-200 bg-white px-4 py-4 shadow-sm">
            <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Next Scheduled</p>
            <% if @next_product_price.present? %>
              <p class="mt-2 text-sm font-medium text-slate-900"><%= money(@next_product_price.price_cents) %></p>
              <p class="mt-1 text-xs text-slate-500"><%= @next_product_price.effective_on.to_fs(:long) %></p>
            <% else %>
              <p class="mt-2 text-sm font-medium text-slate-900">-</p>
            <% end %>
          </div>
        </div>

        <% if @product_price.errors.any? %>
          <div class="flash flash-alert">
            <p class="font-semibold"><%= pluralize(@product_price.errors.count, "error") %> prevented this price from being saved:</p>
            <ul class="mt-2 list-disc pl-5">
              <% @product_price.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="rounded-2xl border border-emerald-200 bg-white px-5 py-5 shadow-sm">
          <div class="mb-4">
            <h4 class="text-base font-semibold text-slate-900">Add Selling Price</h4>
            <p class="mt-1 text-sm text-slate-600">Create a new row in the selling price timeline.</p>
          </div>

          <%= form_with model: [@product, @product_price], class: "grid gap-4 md:grid-cols-[minmax(0,1fr)_220px_auto]" do |f| %>
            <div>
              <%= f.label :price_decimal, "Selling Price", class: "field-label" %>
              <%= f.number_field :price_decimal, value: @product_price.price_decimal, class: "field-input", min: 0, step: "0.0001", placeholder: "0.0000" %>
            </div>
            <div>
              <%= f.label :effective_on, "Effective Date", class: "field-label" %>
              <%= f.date_field :effective_on, class: "field-input" %>
            </div>
            <div class="flex items-end">
              <%= f.submit "Save selling price", class: "btn btn-primary w-full md:w-auto" %>
            </div>
          <% end %>
        </div>

        <div class="rounded-2xl border border-emerald-200 bg-white px-5 py-5 shadow-sm">
          <div class="mb-4">
            <h4 class="text-base font-semibold text-slate-900">Selling Price History</h4>
            <p class="mt-1 text-sm text-slate-600">Latest effective dates appear first.</p>
          </div>

          <% if @product_prices.any? %>
            <div class="table-wrap">
              <table class="table-base">
                <thead>
                  <tr>
                    <th>Effective Date</th>
                    <th>Price</th>
                    <th>Status</th>
                    <th class="text-right">Action</th>
                  </tr>
                </thead>
                <tbody>
                  <% @product_prices.each do |price| %>
                    <% badge = if price.effective_on > Date.current
                      :pending
                    elsif price.id == @current_product_price&.id
                      :active
                    else
                      :inactive
                    end %>
                    <tr>
                      <td data-label="Effective Date"><%= price.effective_on.to_fs(:long) %></td>
                      <td data-label="Price" class="font-semibold text-slate-900"><%= money(price.price_cents) %></td>
                      <td data-label="Status"><%= status_badge(badge) %></td>
                      <td data-label="Action" class="text-right">
                        <% if price.effective_on > Date.current %>
                          <%= button_to product_product_price_path(@product, price), method: :delete, class: "inline-flex h-9 w-9 items-center justify-center rounded-full border border-rose-200 bg-rose-50 text-rose-600 transition hover:bg-rose-100", title: "Delete upcoming selling price", aria: { label: "Delete upcoming selling price" }, form: { data: { turbo_confirm: "Delete this upcoming selling price?" }, class: "inline-block" } do %>
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-4 w-4" aria-hidden="true">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M4 7h16M10 11v6M14 11v6M6 7l1 12h10l1-12M9 7V4h6v3" />
                            </svg>
                          <% end %>
                        <% end %>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% else %>
            <div class="rounded-xl border border-dashed border-emerald-200 bg-emerald-50/50 px-4 py-6 text-sm text-slate-600">
              No selling prices have been added yet.
            </div>
          <% end %>
        </div>
      </div>
    </section>

    <section class="overflow-hidden rounded-2xl border border-amber-200 bg-gradient-to-br from-amber-50 via-white to-orange-100/60 shadow-sm">
      <div class="border-b border-amber-200/80 px-6 py-5">
        <div class="flex items-start justify-between gap-4">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-amber-700">Purchase</p>
            <h3 class="mt-2 text-xl font-semibold text-slate-900">Supplier Cost Track</h3>
            <p class="mt-1 text-sm text-slate-600">Use this when the incoming purchase cost changes over time.</p>
          </div>
          <div class="rounded-full border border-amber-300 bg-white/80 px-3 py-1 text-xs font-medium text-amber-700">
            <%= @product_purchase_prices.count %> entries
          </div>
        </div>
      </div>

      <div class="space-y-6 px-6 py-6">
        <div class="grid gap-3 sm:grid-cols-3">
          <div class="rounded-2xl border border-amber-200 bg-white px-4 py-4 shadow-sm">
            <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Current Cost</p>
            <p class="mt-2 text-2xl font-semibold text-slate-900"><%= @current_product_purchase_price.present? ? money(@current_product_purchase_price.price_cents) : "-" %></p>
          </div>
          <div class="rounded-2xl border border-amber-200 bg-white px-4 py-4 shadow-sm">
            <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Effective Since</p>
            <p class="mt-2 text-sm font-medium text-slate-900"><%= @current_product_purchase_price&.effective_on&.to_fs(:long) || "-" %></p>
          </div>
          <div class="rounded-2xl border border-amber-200 bg-white px-4 py-4 shadow-sm">
            <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Next Scheduled</p>
            <% if @next_product_purchase_price.present? %>
              <p class="mt-2 text-sm font-medium text-slate-900"><%= money(@next_product_purchase_price.price_cents) %></p>
              <p class="mt-1 text-xs text-slate-500"><%= @next_product_purchase_price.effective_on.to_fs(:long) %></p>
            <% else %>
              <p class="mt-2 text-sm font-medium text-slate-900">-</p>
            <% end %>
          </div>
        </div>

        <% if @product_purchase_price.errors.any? %>
          <div class="flash flash-alert">
            <p class="font-semibold"><%= pluralize(@product_purchase_price.errors.count, "error") %> prevented this purchase price from being saved:</p>
            <ul class="mt-2 list-disc pl-5">
              <% @product_purchase_price.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="rounded-2xl border border-amber-200 bg-white px-5 py-5 shadow-sm">
          <div class="mb-4">
            <h4 class="text-base font-semibold text-slate-900">Add Purchase Price</h4>
            <p class="mt-1 text-sm text-slate-600">Create a new row in the purchase cost timeline.</p>
          </div>

          <%= form_with model: [@product, @product_purchase_price], class: "grid gap-4 md:grid-cols-[minmax(0,1fr)_220px_auto]" do |f| %>
            <div>
              <%= f.label :price_decimal, "Purchase Price", class: "field-label" %>
              <%= f.number_field :price_decimal, value: @product_purchase_price.price_decimal, class: "field-input", min: 0, step: "0.0001", placeholder: "0.0000" %>
            </div>
            <div>
              <%= f.label :effective_on, "Effective Date", class: "field-label" %>
              <%= f.date_field :effective_on, class: "field-input" %>
            </div>
            <div class="flex items-end">
              <%= f.submit "Save purchase price", class: "btn btn-primary w-full md:w-auto" %>
            </div>
          <% end %>
        </div>

        <div class="rounded-2xl border border-amber-200 bg-white px-5 py-5 shadow-sm">
          <div class="mb-4">
            <h4 class="text-base font-semibold text-slate-900">Purchase Price History</h4>
            <p class="mt-1 text-sm text-slate-600">Latest effective dates appear first.</p>
          </div>

          <% if @product_purchase_prices.any? %>
            <div class="table-wrap">
              <table class="table-base">
                <thead>
                  <tr>
                    <th>Effective Date</th>
                    <th>Purchase Price</th>
                    <th>Status</th>
                    <th class="text-right">Action</th>
                  </tr>
                </thead>
                <tbody>
                  <% @product_purchase_prices.each do |price| %>
                    <% badge = if price.effective_on > Date.current
                      :pending
                    elsif price.id == @current_product_purchase_price&.id
                      :active
                    else
                      :inactive
                    end %>
                    <tr>
                      <td data-label="Effective Date"><%= price.effective_on.to_fs(:long) %></td>
                      <td data-label="Purchase Price" class="font-semibold text-slate-900"><%= money(price.price_cents) %></td>
                      <td data-label="Status"><%= status_badge(badge) %></td>
                      <td data-label="Action" class="text-right">
                        <% if price.effective_on > Date.current %>
                          <%= button_to product_product_purchase_price_path(@product, price), method: :delete, class: "inline-flex h-9 w-9 items-center justify-center rounded-full border border-rose-200 bg-rose-50 text-rose-600 transition hover:bg-rose-100", title: "Delete upcoming purchase price", aria: { label: "Delete upcoming purchase price" }, form: { data: { turbo_confirm: "Delete this upcoming purchase price?" }, class: "inline-block" } do %>
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-4 w-4" aria-hidden="true">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M4 7h16M10 11v6M14 11v6M6 7l1 12h10l1-12M9 7V4h6v3" />
                            </svg>
                          <% end %>
                        <% end %>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% else %>
            <div class="rounded-xl border border-dashed border-amber-200 bg-amber-50/50 px-4 py-6 text-sm text-slate-600">
              No purchase prices have been added yet.
            </div>
          <% end %>
        </div>
      </div>
    </section>
  </div>
</section>

<%= form_with model: customer, class: "card space-y-4" do |f| %>
  <%= hidden_field_tag :return_to, params[:return_to] if params[:return_to].present? %>

  <% if customer.errors.any? %>
    <div class="flash flash-alert">
      <p class="font-semibold"><%= pluralize(customer.errors.count, "error") %> prevented this customer from being saved:</p>
      <ul class="mt-2 list-disc pl-5">
        <% customer.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid gap-4 md:grid-cols-2">
    <div>
      <%= f.label :name, class: "field-label" %>
      <%= f.text_field :name, class: "field-input", placeholder: "Customer name" %>
    </div>

    <div>
      <%= f.label :contact_name, class: "field-label" %>
      <%= f.text_field :contact_name, class: "field-input", placeholder: "Primary contact" %>
    </div>

    <div>
      <%= f.label :contact_email, class: "field-label" %>
      <%= f.email_field :contact_email, class: "field-input", placeholder: "name@example.com" %>
    </div>

    <div>
      <%= f.label :contact_phone, class: "field-label" %>
      <%= f.text_field :contact_phone, class: "field-input", placeholder: "Phone number" %>
    </div>

    <div class="md:col-span-2">
      <%= f.label :address, class: "field-label" %>
      <%= f.text_area :address, class: "field-input", rows: 3, placeholder: "Delivery address" %>
    </div>
  </div>

  <div class="flex flex-wrap gap-2">
    <%= f.submit class: "btn btn-primary" %>
    <%= link_to "Cancel", (@cancel_path || customers_path), class: "btn btn-secondary" %>
  </div>
<% end %>

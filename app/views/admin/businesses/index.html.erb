<div class="mb-6 flex flex-wrap items-end justify-between gap-3">
  <div>
    <h1 class="page-title">Admin Businesses</h1>
    <p class="mt-1 text-sm text-slate-600">Tenant directory and membership counts.</p>
  </div>
  <div class="flex flex-wrap gap-2">
    <%= link_to "New Business", new_admin_business_path, class: "btn btn-primary" %>
    <%= link_to "System Admin Home", admin_root_path, class: "btn btn-secondary" %>
  </div>
</div>

<section class="card">
  <% if @businesses.any? %>
    <div class="table-wrap">
      <table class="table-base">
        <thead>
          <tr>
            <th>Name</th>
            <th>Members</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @businesses.each do |business| %>
            <tr>
              <td class="font-medium text-slate-900"><%= business.name %></td>
              <td><%= business.memberships.size %></td>
              <td class="text-right"><%= link_to "View", admin_business_path(business), class: "btn btn-ghost" %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <p class="empty-state">No businesses found.</p>
  <% end %>
</section>

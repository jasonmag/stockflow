<div class="mb-6">
  <h1 class="page-title">Edit Admin Access</h1>
  <p class="mt-1 text-sm text-slate-600"><%= @user.email_address %></p>
</div>

<section class="card">
  <%= form_with model: [ :admin, @user ], class: "space-y-4" do |f| %>
    <% if @user.errors.any? %>
      <div class="flash flash-alert">
        <p class="font-semibold"><%= pluralize(@user.errors.count, "error") %> prevented this user from being saved:</p>
        <ul class="mt-2 list-disc pl-5">
          <% @user.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="flex items-center gap-2">
      <%= f.check_box :system_admin %>
      <%= f.label :system_admin, "System admin", class: "field-label !mb-0" %>
    </div>

    <div class="flex flex-wrap gap-2">
      <%= f.submit "Save", class: "btn btn-primary" %>
      <%= link_to "Cancel", admin_user_path(@user), class: "btn btn-secondary" %>
    </div>
  <% end %>
</section>

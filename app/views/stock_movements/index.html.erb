<div class="mb-6 flex flex-wrap items-end justify-between gap-3">
  <div>
    <h1 class="page-title">Stock Movements</h1>
    <p class="mt-1 text-sm text-slate-600">Inventory ledger of stock in, out, transfers, and adjustments.</p>
  </div>
  <%= link_to "New Stock Movement", new_stock_movement_path, class: "btn btn-primary" %>
</div>

<% if @current_inventory_rows.any? %>
  <section class="card mb-4">
    <h2 class="mb-3 text-base font-semibold text-slate-900">Current Counts By Location</h2>
    <div class="space-y-4">
      <% @current_inventory_rows.each do |location_name, rows| %>
        <section class="rounded-lg border border-slate-200">
          <div class="border-b border-slate-200 bg-slate-50 px-4 py-3">
            <h3 class="text-sm font-semibold text-slate-900"><%= location_name %></h3>
          </div>
          <div class="table-wrap">
            <table class="table-base">
              <thead>
                <tr>
                  <th>Product</th>
                  <th>Current Count</th>
                </tr>
              </thead>
              <tbody>
                <% rows.each do |row| %>
                  <tr>
                    <td class="font-medium text-slate-900"><%= row[:product_name] %></td>
                    <td><%= number_with_precision(row[:quantity], precision: 2, strip_insignificant_zeros: true) %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </section>
      <% end %>
    </div>
  </section>
<% end %>

<% if @stock_movements.any? %>
  <div class="table-wrap">
    <table class="table-base">
      <thead>
        <tr>
          <th>Date</th>
          <th>Type</th>
          <th>Product</th>
          <th>Quantity</th>
          <th>From</th>
          <th>To</th>
        </tr>
      </thead>
      <tbody>
        <% @stock_movements.each do |row| %>
          <tr>
            <td><%= row.occurred_on.to_fs(:long) %></td>
            <td><%= status_badge(row.movement_type) %></td>
            <td class="font-medium text-slate-900"><%= row.product.name %></td>
            <td><%= row.quantity %></td>
            <td><%= row.from_location&.name || "-" %></td>
            <td><%= row.to_location&.name || "-" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <p class="empty-state">No stock movements yet. Add one to start your inventory ledger.</p>
<% end %>

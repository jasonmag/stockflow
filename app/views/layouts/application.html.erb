<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Stockflow" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>
    <script>
      (() => {
        const validThemes = ["light", "dark"];
        let theme = "light";
        try {
          const storedTheme = localStorage.getItem("stockflow-theme");
          if (storedTheme === "ocean" || storedTheme === "forest" || storedTheme === "classic") {
            theme = "light";
          } else if (validThemes.includes(storedTheme)) {
            theme = storedTheme;
          }
        } catch (_error) {}
        document.documentElement.setAttribute("data-theme", theme);
      })();
    </script>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body data-controller="theme">
    <div class="min-h-screen">
      <nav class="app-nav backdrop-blur">
        <div class="mx-auto max-w-7xl px-4 py-4">
          <div class="flex flex-wrap items-center justify-between gap-4">
            <div class="flex min-w-0 items-center gap-3">
              <%= link_to(Current.user ? dashboard_path : root_path, class: "brand-pill") do %>
                STOCKFLOW
              <% end %>
              <% if Current.user && current_business.present? %>
                <p class="truncate text-sm font-medium text-slate-900"><%= current_business.name %></p>
              <% end %>
            </div>

            <div class="flex w-full flex-wrap items-center justify-between gap-3 lg:w-auto lg:justify-end">
              <div class="theme-toggle" role="group" aria-label="Theme">
                <button type="button"
                        class="theme-toggle-option"
                        aria-label="Light theme"
                        aria-pressed="false"
                        data-theme-target="option"
                        data-theme-value="light"
                        data-action="click->theme#set">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-5 w-5" aria-hidden="true">
                    <circle cx="12" cy="12" r="4"></circle>
                    <path stroke-linecap="round" d="M12 2.75v2.5M12 18.75v2.5M21.25 12h-2.5M5.25 12h-2.5M18.54 5.46l-1.77 1.77M7.23 16.77l-1.77 1.77M18.54 18.54l-1.77-1.77M7.23 7.23L5.46 5.46"></path>
                  </svg>
                </button>
                <button type="button"
                        class="theme-toggle-option"
                        aria-label="Dark theme"
                        aria-pressed="false"
                        data-theme-target="option"
                        data-theme-value="dark"
                        data-action="click->theme#set">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-5 w-5" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 14.25A8.25 8.25 0 0 1 9.75 3.75a8.25 8.25 0 1 0 10.5 10.5Z"></path>
                  </svg>
                </button>
              </div>

              <% if Current.user %>
                <span class="nav-meta hidden md:inline"><%= Current.user.email_address %></span>
              <% end %>

              <% if Current.user %>
                <% if impersonating? %>
                  <div class="w-full rounded-xl border border-amber-300 bg-amber-50 px-3 py-2 text-xs text-amber-900 lg:w-auto">
                    Impersonating <span class="font-semibold"><%= Current.user.email_address %></span>
                    <%= button_to "Stop", admin_impersonation_path, method: :delete, class: "ml-2 inline-flex rounded-md border border-amber-400 px-2 py-1 text-xs font-medium text-amber-900 hover:bg-amber-100" %>
                  </div>
                <% end %>

                <% if (!system_admin? || impersonating?) && Current.user.businesses.any? %>
                  <%= form_with url: switch_business_path, method: :patch, class: "nav-utility w-full lg:w-auto" do |f| %>
                    <%= f.select :business_id,
                      options_from_collection_for_select(Current.user.businesses, :id, :name, current_business&.id),
                      {},
                      class: "field-input min-w-0 md:w-56" %>
                    <%= f.submit "Switch", class: "btn btn-secondary" %>
                  <% end %>
                <% end %>

                <%= button_to "Sign out", session_path, method: :delete, class: "btn btn-ghost", form: { class: "w-full lg:w-auto" } %>
              <% else %>
                <div class="flex flex-wrap gap-2">
                  <%= link_to "Home", root_path, class: "btn btn-ghost" %>
                  <%= link_to "About", about_path, class: "btn btn-ghost" %>
                  <%= link_to "Register", new_registration_path, class: "btn btn-ghost" %>
                  <%= link_to "User login", login_path, class: "btn btn-primary" %>
                  <%= link_to "Admin login", admin_login_path, class: "btn btn-secondary" %>
                </div>
              <% end %>
            </div>
          </div>

          <% if Current.user %>
            <% if system_admin? && !impersonating? %>
              <div class="mt-4 flex flex-wrap items-center gap-2 border-t border-slate-200 pt-4">
                <%= nav_link_to "Admin Dashboard", admin_root_path %>
              </div>
            <% else %>
              <div class="mt-4 flex flex-wrap items-center gap-2 border-t border-slate-200 pt-4">
                <%= nav_link_to "Dashboard", dashboard_path %>
                <%= nav_link_to "Purchases", purchases_path %>
                <%= nav_link_to "Deliveries", deliveries_path %>
                <%= nav_link_to "Inventory", stock_movements_path %>
                <%= nav_link_to "Products", products_path %>
                <%= nav_link_to "Expenses", expenses_path %>
                <%= nav_link_to "Receivables", receivables_path %>
                <%= nav_link_to "Payables", payables_path %>
                <%= nav_link_to "User Guide", user_guide_path %>
                <%= nav_link_to "Notifications", notifications_path %>
                <% if owner? %>
                  <%= nav_link_to "Business Settings", edit_business_path %>
                  <%= nav_link_to "Members", members_business_path %>
                <% end %>
                <% if system_admin? %>
                  <%= nav_link_to "Admin", admin_root_path %>
                <% end %>
              </div>
            <% end %>
          <% end %>
        </div>
      </nav>

      <main class="mx-auto max-w-7xl px-4 py-6">
        <% if notice.present? %><p class="flash flash-notice"><%= notice %></p><% end %>
        <% if alert.present? %><p class="flash flash-alert"><%= alert %></p><% end %>
        <%= yield %>
      </main>
    </div>
  </body>
</html>

<!DOCTYPE html>
<html>
  <head>
    <title><%= page_title %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="<%= meta_description %>">
    <meta name="theme-color" content="#0f766e">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="Stockflow">
    <meta property="og:title" content="<%= page_title %>">
    <meta property="og:description" content="<%= meta_description %>">
    <meta property="og:url" content="<%= canonical_url %>">
    <meta property="og:image" content="<%= meta_image_url %>">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= page_title %>">
    <meta name="twitter:description" content="<%= meta_description %>">
    <meta name="twitter:image" content="<%= meta_image_url %>">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>
    <script>
      (() => {
        const validThemes = ["light", "dark"];
        let theme = "light";
        try {
          const storedTheme = localStorage.getItem("stockflow-theme");
          if (storedTheme === "ocean" || storedTheme === "forest" || storedTheme === "classic") {
            theme = "light";
          } else if (validThemes.includes(storedTheme)) {
            theme = storedTheme;
          }
        } catch (_error) {}
        document.documentElement.setAttribute("data-theme", theme);
      })();
    </script>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="icon" href="/icon.png" sizes="512x512" type="image/png">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body data-controller="theme mobile-nav">
    <div class="min-h-screen">
      <nav class="app-nav backdrop-blur">
        <div class="mx-auto max-w-7xl px-4 py-4">
          <div class="flex items-center justify-between gap-4">
            <div class="flex min-w-0 items-center gap-3">
              <%= link_to(Current.user ? dashboard_path : root_path, class: "brand-pill") do %>
                STOCKFLOW
              <% end %>
              <% if Current.user && current_business.present? %>
                <p class="hidden truncate text-sm font-medium text-slate-900 sm:block"><%= current_business.name %></p>
              <% end %>
            </div>

            <div class="flex items-center gap-2">
              <div class="hidden md:flex md:items-center">
                <%= render "layouts/nav_utilities" %>
              </div>

              <div class="theme-toggle" role="group" aria-label="Theme">
                <button type="button"
                        class="theme-toggle-option"
                        aria-label="Light theme"
                        aria-pressed="false"
                        data-theme-target="option"
                        data-theme-value="light"
                        data-action="click->theme#set">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-5 w-5" aria-hidden="true">
                    <circle cx="12" cy="12" r="4"></circle>
                    <path stroke-linecap="round" d="M12 2.75v2.5M12 18.75v2.5M21.25 12h-2.5M5.25 12h-2.5M18.54 5.46l-1.77 1.77M7.23 16.77l-1.77 1.77M18.54 18.54l-1.77-1.77M7.23 7.23L5.46 5.46"></path>
                  </svg>
                </button>
                <button type="button"
                        class="theme-toggle-option"
                        aria-label="Dark theme"
                        aria-pressed="false"
                        data-theme-target="option"
                        data-theme-value="dark"
                        data-action="click->theme#set">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="h-5 w-5" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 14.25A8.25 8.25 0 0 1 9.75 3.75a8.25 8.25 0 1 0 10.5 10.5Z"></path>
                  </svg>
                </button>
              </div>

              <button type="button"
                      class="nav-menu-toggle md:hidden"
                      aria-controls="primary-navigation"
                      aria-expanded="false"
                      data-action="click->mobile-nav#toggle"
                      data-mobile-nav-target="toggle">
                Menu
              </button>
            </div>
          </div>

          <div id="primary-navigation" class="nav-panel" data-mobile-nav-target="panel">
            <div class="nav-section md:hidden">
              <%= render "layouts/nav_utilities" %>
            </div>

            <% if Current.user %>
              <% if system_admin? && !impersonating? %>
                <div class="nav-section nav-links">
                  <%= nav_link_to "Admin Dashboard", admin_root_path %>
                </div>
              <% else %>
                <div class="nav-section nav-links">
                  <%= nav_link_to "Dashboard", dashboard_path %>
                  <%= nav_link_to "Purchases", purchases_path %>
                  <%= nav_link_to "Deliveries", deliveries_path %>
                  <%= nav_link_to "Inventory", stock_movements_path %>
                  <%= nav_link_to "Products", products_path %>
                  <%= nav_link_to "Expenses", expenses_path %>
                  <%= nav_link_to "Receivables", receivables_path %>
                  <%= nav_link_to "Payables", payables_path %>
                  <%= nav_link_to "User Guide", user_guide_path %>
                  <%= nav_link_to "Notifications", notifications_path %>
                  <% if owner? %>
                    <%= nav_link_to "Business Settings", edit_business_path %>
                    <%= nav_link_to "Members", members_business_path %>
                  <% end %>
                  <% if system_admin? %>
                    <%= nav_link_to "Admin", admin_root_path %>
                  <% end %>
                </div>
              <% end %>
            <% end %>
          </div>
        </div>
      </nav>

      <main class="mx-auto max-w-7xl px-4 py-5 md:py-6">
        <% if notice.present? %><p class="flash flash-notice"><%= notice %></p><% end %>
        <% if alert.present? %><p class="flash flash-alert"><%= alert %></p><% end %>
        <%= yield %>
      </main>
    </div>
  </body>
</html>

<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Stockflow" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>
    <script>
      (() => {
        const validThemes = ["ocean", "forest", "classic"];
        let theme = "ocean";
        try {
          const storedTheme = localStorage.getItem("stockflow-theme");
          if (validThemes.includes(storedTheme)) theme = storedTheme;
        } catch (_error) {}
        document.documentElement.setAttribute("data-theme", theme);
      })();
    </script>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body data-controller="theme">
    <div class="min-h-screen">
      <nav class="app-nav backdrop-blur">
        <div class="mx-auto max-w-7xl px-4 py-4">
          <div class="flex flex-wrap items-center justify-between gap-3">
            <div class="flex items-center gap-3">
              <%= link_to root_path, class: "brand-pill" do %>
                STOCKFLOW
              <% end %>
              <% if Current.user %>
                <span class="hidden text-xs text-slate-500 md:inline">Business operations hub</span>
              <% end %>
            </div>

            <div class="flex w-full flex-wrap items-center gap-2 md:w-auto">
              <select class="field-input md:w-36"
                      aria-label="Theme"
                      data-theme-target="select"
                      data-action="change->theme#change">
                <option value="ocean">Ocean</option>
                <option value="forest">Forest</option>
                <option value="classic">Classic</option>
              </select>
              <% if Current.user %>
                <% if impersonating? %>
                  <div class="w-full rounded-lg border border-amber-300 bg-amber-50 px-3 py-2 text-xs text-amber-900 md:w-auto">
                    Impersonating <span class="font-semibold"><%= Current.user.email_address %></span>
                    <%= button_to "Stop", admin_impersonation_path, method: :delete, class: "ml-2 inline-flex rounded-md border border-amber-400 px-2 py-1 text-xs font-medium text-amber-900 hover:bg-amber-100" %>
                  </div>
                <% end %>
                <% if (!system_admin? || impersonating?) && Current.user.businesses.any? %>
                  <%= form_with url: switch_business_path, method: :patch, class: "flex w-full items-center gap-2 md:w-auto" do |f| %>
                    <%= f.select :business_id,
                      options_from_collection_for_select(Current.user.businesses, :id, :name, current_business&.id),
                      {},
                      class: "field-input md:w-56" %>
                    <%= f.submit "Switch", class: "btn btn-secondary" %>
                  <% end %>
                <% end %>
                <%= button_to "Sign out", session_path, method: :delete, class: "btn btn-ghost", form: { class: "w-full md:w-auto" } %>
              <% else %>
                <%= link_to "Home", root_path, class: "btn btn-ghost" %>
                <%= link_to "About", about_path, class: "btn btn-ghost" %>
                <%= link_to "User login", login_path, class: "btn btn-primary" %>
                <%= link_to "Admin login", admin_login_path, class: "btn btn-secondary" %>
              <% end %>
            </div>
          </div>

          <% if Current.user %>
            <div class="mt-3 flex flex-wrap items-center gap-1 border-t border-slate-200 pt-3">
              <% if system_admin? && !impersonating? %>
                <%= nav_link_to "Admin", admin_root_path %>
              <% else %>
                <%= nav_link_to "Dashboard", dashboard_path %>
                <%= nav_link_to "Expenses", expenses_path %>
                <%= nav_link_to "Payables", payables_path %>
                <%= nav_link_to "Receivables", receivables_path %>
                <%= nav_link_to "Purchases", purchases_path %>
                <%= nav_link_to "Deliveries", deliveries_path %>
                <%= nav_link_to "Inventory", stock_movements_path %>
                <%= nav_link_to "User Guide", user_guide_path %>
                <% if system_admin? %>
                  <%= nav_link_to "Admin", admin_root_path %>
                <% end %>
              <% end %>
            </div>
          <% end %>
        </div>
      </nav>

      <main class="mx-auto max-w-7xl px-4 py-6">
        <% if notice.present? %><p class="flash flash-notice"><%= notice %></p><% end %>
        <% if alert.present? %><p class="flash flash-alert"><%= alert %></p><% end %>
        <%= yield %>
      </main>
    </div>
  </body>
</html>

<div class="grid gap-3 items-start rounded-lg bg-white p-1 md:grid-cols-[minmax(0,2.2fr)_minmax(110px,0.8fr)_minmax(130px,0.9fr)_minmax(130px,0.9fr)_auto] md:items-center md:rounded-none md:bg-transparent md:p-0" data-controller="purchase-item-total" data-nested-purchase-items-target="item">
  <%= form.hidden_field :_destroy, value: "0", data: { nested_purchase_items_target: "destroyField" } %>
  <div data-mobile-label="Product">
    <%= form.select :product_id,
      options_for_select(
        [["Select product", ""]] + products.map do |product|
          [
            product.name,
            product.id,
            { "data-current-unit-cost": (product.current_purchase_price_cents.present? ? MoneyPrecision.to_formatted_decimal(product.current_purchase_price_cents) : "") }
          ]
        end,
        form.object.product_id
      ),
      {},
      class: "field-input",
      data: { action: "change->nested-purchase-items#productChanged", nested_purchase_items_target: "productField" } %>
  </div>
  <div data-mobile-label="Quantity">
    <%= form.number_field :quantity, step: 0.01, min: 0.01, class: "field-input", placeholder: "0.00", aria: { label: "Quantity" }, data: { action: "input->purchase-item-total#update", purchase_item_total_target: "quantity" } %>
  </div>
  <div data-mobile-label="Unit cost">
    <%= form.number_field :unit_cost_decimal, step: "0.0001", min: 0.0001, class: "field-input", placeholder: "0.0000", aria: { label: "Unit cost" }, data: { action: "input->purchase-item-total#update keydown.enter->nested-purchase-items#addFromUnitCost keydown.tab->nested-purchase-items#addFromUnitCost", purchase_item_total_target: "unitCost" } %>
  </div>
  <div data-mobile-label="Sub-total">
    <div class="purchase-item-subtotal" data-purchase-item-total-target="subtotal">PHP 0.00</div>
  </div>
  <div class="flex items-center justify-end md:justify-start">
    <button type="button" class="btn btn-ghost" data-action="click->nested-purchase-items#remove">Remove</button>
  </div>
</div>

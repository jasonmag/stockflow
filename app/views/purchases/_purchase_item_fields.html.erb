<div class="grid gap-3 items-start md:grid-cols-[minmax(0,2.2fr)_minmax(110px,0.8fr)_minmax(130px,0.9fr)_minmax(130px,0.9fr)_auto] md:items-center" data-controller="purchase-item-total" data-nested-purchase-items-target="item">
  <%= form.hidden_field :_destroy, value: "0", data: { nested_purchase_items_target: "destroyField" } %>
  <div>
    <%= form.collection_select :product_id, products, :id, :name, { prompt: "Select product" }, class: "field-input", data: { nested_purchase_items_target: "productField" } %>
  </div>
  <div>
    <%= form.number_field :quantity, step: 0.01, min: 0.01, class: "field-input", placeholder: "0.00", aria: { label: "Quantity" }, data: { action: "input->purchase-item-total#update", purchase_item_total_target: "quantity" } %>
  </div>
  <div>
    <%= form.number_field :unit_cost_decimal, step: 0.01, min: 0.01, class: "field-input", placeholder: "0.00", aria: { label: "Unit cost" }, data: { action: "input->purchase-item-total#update keydown.enter->nested-purchase-items#addFromUnitCost keydown.tab->nested-purchase-items#addFromUnitCost", purchase_item_total_target: "unitCost" } %>
  </div>
  <div>
    <div class="purchase-item-subtotal" data-purchase-item-total-target="subtotal">PHP 0.00</div>
  </div>
  <div class="flex items-center justify-end md:justify-start">
    <button type="button" class="btn btn-ghost" data-action="click->nested-purchase-items#remove">Remove</button>
  </div>
</div>

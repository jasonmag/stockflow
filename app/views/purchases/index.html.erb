<div class="mb-6 flex flex-wrap items-end justify-between gap-3">
  <div>
    <h1 class="page-title">Purchases</h1>
    <p class="mt-1 text-sm text-slate-600">Track supplier purchases and stock receiving state.</p>
  </div>
  <%= link_to "New Purchase", new_purchase_path, class: "btn btn-primary" %>
</div>

<% if @purchases.any? %>
  <div class="table-wrap">
    <table class="table-base">
      <thead>
        <tr>
          <th>Purchase</th>
          <th>Supplier</th>
          <th>Purchased On</th>
          <th>Status</th>
          <th class="text-right">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @purchases.each do |purchase| %>
          <tr>
            <td class="font-medium text-slate-900"><%= link_to purchase.reference.presence || "Purchase ##{purchase.id}", purchase, class: "hover:underline" %></td>
            <td><%= purchase.supplier.name %></td>
            <td><%= purchase.purchased_on.to_fs(:long) %></td>
            <td><%= status_badge(purchase.status) %></td>
            <td class="text-right">
              <div class="flex justify-end gap-2">
                <%= link_to "View", purchase, class: "btn btn-ghost" %>
                <% unless purchase.received? %>
                  <%= button_to "Delete", purchase_path(purchase), method: :delete, class: "btn btn-ghost", form: { data: { turbo_confirm: "Delete this draft purchase?" } } %>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <p class="empty-state">No purchases yet. Create one to receive inventory from suppliers.</p>
<% end %>

<%= form_with model: purchase, class: "card space-y-4", data: { controller: "purchase-reference" } do |f| %>
  <% if purchase.errors.any? %>
    <div class="flash flash-alert">
      <p class="font-semibold"><%= pluralize(purchase.errors.count, "error") %> prevented this purchase from being saved:</p>
      <ul class="mt-2 list-disc pl-5">
        <% purchase.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid gap-4 md:grid-cols-2">
    <div>
      <%= f.label :reference, "Name", class: "field-label" %>
      <%= f.text_field :reference, class: "field-input", readonly: true, data: { purchase_reference_target: "reference" } %>
    </div>

    <div>
      <%= f.label :supplier_id, class: "field-label" %>
      <%= f.collection_select :supplier_id, current_business.suppliers.order(:name), :id, :name, { prompt: "Select supplier" }, class: "field-input" %>
      <div class="mt-2 flex items-center gap-2 text-xs text-slate-600">
        <span>Supplier not listed?</span>
        <%= link_to "Add new supplier", new_supplier_path(return_to: new_purchase_path), class: "font-semibold text-slate-900 hover:underline" %>
      </div>
    </div>

    <div>
      <%= f.label :purchased_on, class: "field-label" %>
      <%= f.date_field :purchased_on, class: "field-input", data: { action: "input->purchase-reference#sync change->purchase-reference#sync", purchase_reference_target: "date" } %>
    </div>

    <div>
      <%= f.label :receiving_location_id, class: "field-label" %>
      <%= f.collection_select :receiving_location_id, current_business.locations.order(:name), :id, :name, { prompt: "Select location" }, class: "field-input" %>
      <div class="mt-2 flex items-center gap-2 text-xs text-slate-600">
        <span>Location not listed?</span>
        <%= link_to "Add new location", new_location_path(return_to: new_purchase_path), class: "font-semibold text-slate-900 hover:underline" %>
      </div>
    </div>

    <div>
      <%= f.label :funding_source, class: "field-label" %>
      <%= f.select :funding_source, current_business.purchase_funding_source_options, {}, class: "field-input" %>
      <div class="mt-2 flex items-center gap-2 text-xs text-slate-600">
        <span>Funding source not listed?</span>
        <%= link_to "Add new funding source", new_purchase_funding_source_path(return_to: new_purchase_path), class: "font-semibold text-slate-900 hover:underline" %>
      </div>
    </div>

    <div>
      <%= f.label :status, class: "field-label" %>
      <%= f.select :status, Purchase.statuses.keys.map { |value| [value.humanize, value] }, {}, class: "field-input" %>
    </div>

    <div class="md:col-span-2">
      <%= f.label :notes, class: "field-label" %>
      <%= f.text_area :notes, class: "field-input", rows: 3 %>
    </div>

    <div class="md:col-span-2">
      <%= f.label :purchase_image, "Purchase Picture", class: "field-label" %>
      <%= f.file_field :purchase_image, class: "field-input", accept: "image/*" %>
      <p class="mt-1 text-xs text-slate-600">Upload the supplier receipt, purchase photo, or invoice image. When Google Drive storage is connected, Stockflow also syncs this file to the configured Drive folder.</p>
    </div>
  </div>

  <section class="rounded-lg border border-slate-200 p-4">
    <h2 class="text-sm font-semibold text-slate-900">Purchase Items</h2>
    <p class="mt-1 text-xs text-slate-600">Add at least one item and quantity.</p>

    <div class="mt-3 space-y-3" data-controller="nested-purchase-items" data-action="purchase-items:recalculate->nested-purchase-items#updateOverall">
      <div class="rounded-lg border border-slate-200">
        <div class="hidden border-b border-slate-200 bg-slate-50 px-3 py-2 text-xs font-semibold uppercase tracking-wide text-slate-600 md:grid md:grid-cols-[minmax(0,2.2fr)_minmax(110px,0.8fr)_minmax(130px,0.9fr)_minmax(130px,0.9fr)_auto] md:gap-3">
          <div>Product</div>
          <div>Quantity</div>
          <div>Unit cost</div>
          <div>Sub-total</div>
          <div>Action</div>
        </div>

        <div data-nested-purchase-items-target="list" class="divide-y divide-slate-200 p-3 space-y-3 md:space-y-0">
        <%= f.fields_for :purchase_items do |item| %>
          <%= render "purchase_item_fields", form: item, products: current_business.products.order(:name) %>
        <% end %>
        </div>
      </div>

      <div class="flex justify-end">
        <div class="purchase-items-overall-total">
          <span class="purchase-items-overall-total-label">Total</span>
          <span data-nested-purchase-items-target="overall">PHP 0.00</span>
        </div>
      </div>

      <template data-nested-purchase-items-target="template">
        <%= f.fields_for :purchase_items, PurchaseItem.new, child_index: "NEW_RECORD" do |item| %>
          <%= render "purchase_item_fields", form: item, products: current_business.products.order(:name) %>
        <% end %>
      </template>

      <div class="flex flex-wrap gap-2">
        <button type="button" class="btn btn-secondary" data-action="click->nested-purchase-items#add">Add another product</button>
        <%= link_to "Add new inventory variant", new_product_path(return_to: new_purchase_path), class: "btn btn-secondary" %>
      </div>
    </div>
  </section>

  <div class="flex flex-wrap gap-2">
    <%= f.submit class: "btn btn-primary" %>
    <%= link_to "Cancel", purchases_path, class: "btn btn-secondary" %>
  </div>
<% end %>

<div class="mb-6 flex flex-wrap items-end justify-between gap-3">
  <div>
    <h1 class="page-title"><%= @purchase.reference.presence || "Purchase ##{@purchase.id}" %></h1>
    <p class="mt-1 text-sm text-slate-600">Purchase record and itemized costs.</p>
  </div>
  <div class="flex flex-wrap gap-2">
    <% unless @purchase.received? %>
      <%= link_to "Edit", edit_purchase_path(@purchase), class: "btn btn-primary" %>
      <%= button_to "Delete", purchase_path(@purchase), method: :delete, class: "btn btn-secondary", form: { data: { turbo_confirm: "Delete this draft purchase?" } } %>
    <% end %>
    <%= link_to "Back", purchases_path, class: "btn btn-secondary" %>
  </div>
</div>

<section class="card mb-4">
  <dl class="grid gap-4 sm:grid-cols-2">
    <div>
      <dt class="kpi-label">Name</dt>
      <dd class="mt-1 text-sm text-slate-900"><%= @purchase.reference.presence || "-" %></dd>
    </div>
    <div>
      <dt class="kpi-label">Supplier</dt>
      <dd class="mt-1 text-sm text-slate-900"><%= @purchase.supplier.name %></dd>
    </div>
    <div>
      <dt class="kpi-label">Status</dt>
      <dd class="mt-1"><%= status_badge(@purchase.status) %></dd>
    </div>
    <div>
      <dt class="kpi-label">Purchased On</dt>
      <dd class="mt-1 text-sm text-slate-900"><%= @purchase.purchased_on.to_fs(:long) %></dd>
    </div>
    <div>
      <dt class="kpi-label">Received</dt>
      <dd class="mt-1 text-sm text-slate-900"><%= @purchase.received_at&.to_fs(:long) || "-" %></dd>
    </div>
    <div>
      <dt class="kpi-label">Receiving Location</dt>
      <dd class="mt-1 text-sm text-slate-900"><%= @purchase.receiving_location.name %></dd>
    </div>
    <div>
      <dt class="kpi-label">Funding Source</dt>
      <dd class="mt-1 text-sm text-slate-900"><%= @purchase.funding_source %></dd>
    </div>
    <div>
      <dt class="kpi-label">Expense Reference</dt>
      <dd class="mt-1 text-sm text-slate-900">
        <% if @purchase.expense.present? %>
          <%= link_to "View Expense", expense_path(@purchase.expense), class: "btn btn-ghost" %>
        <% else %>
          <span class="text-slate-600">No expense reference yet.</span>
        <% end %>
      </dd>
    </div>
    <div class="sm:col-span-2">
      <dt class="kpi-label">Notes</dt>
      <dd class="mt-1 text-sm text-slate-900"><%= @purchase.notes.presence || "-" %></dd>
    </div>
    <div class="sm:col-span-2">
      <dt class="kpi-label">Purchase Picture</dt>
      <dd class="mt-2 flex flex-wrap gap-2">
        <% if @purchase.purchase_image.attached? %>
          <% purchase_image_url = @purchase.purchase_image_storage_url.presence || rails_blob_path(@purchase.purchase_image, disposition: "attachment") %>
          <%= link_to "View Purchase", purchase_image_url, class: "btn btn-ghost", target: "_blank", rel: "noopener noreferrer" %>
          <% if @purchase.purchase_image_storage_synced_at.present? %>
            <span class="text-sm text-slate-600">Synced to Google Drive on <%= @purchase.purchase_image_storage_synced_at.to_fs(:long) %>.</span>
          <% elsif @purchase.purchase_image_storage_error.present? %>
            <span class="text-sm text-rose-600"><%= @purchase.purchase_image_storage_error %></span>
          <% else %>
            <span class="text-sm text-slate-600">Attached in Stockflow.</span>
          <% end %>
        <% else %>
          <span class="text-sm text-slate-600">No picture uploaded.</span>
        <% end %>
      </dd>
    </div>
  </dl>
</section>

<section class="card mb-4">
  <h2 class="mb-3 text-base font-semibold text-slate-900">Items</h2>
  <% if @purchase.purchase_items.any? %>
    <% total_cents = @purchase.purchase_items.sum { |item| (item.unit_cost_cents * item.quantity.to_d).round(0) } %>
    <div class="table-wrap">
      <table class="table-base">
        <thead>
          <tr>
            <th>Product</th>
            <th>Quantity</th>
            <th>Unit Cost</th>
            <th>Sub-total</th>
          </tr>
        </thead>
        <tbody>
          <% @purchase.purchase_items.each do |item| %>
            <tr>
              <td data-label="Product" class="font-medium text-slate-900"><%= item.product.name %></td>
              <td data-label="Quantity"><%= item.quantity %></td>
              <td data-label="Unit Cost"><%= money(item.unit_cost_cents) %></td>
              <td data-label="Sub-total"><%= money((item.unit_cost_cents * item.quantity.to_d).round(0)) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <div class="mt-4 flex justify-end">
      <div class="purchase-items-overall-total">
        <span class="purchase-items-overall-total-label">Total</span>
        <span><%= money(total_cents) %></span>
      </div>
    </div>
  <% else %>
    <p class="text-sm text-slate-600">No purchase items attached.</p>
  <% end %>
</section>

<% unless @purchase.received? %>
  <%= button_to "Receive", receive_purchase_path(@purchase), method: :patch, class: "btn btn-secondary" %>
<% end %>

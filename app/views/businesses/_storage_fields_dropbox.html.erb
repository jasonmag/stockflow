<div class="grid gap-4 md:grid-cols-2">
  <div>
    <%= storage_form.label :app_key, "Dropbox App Key", class: "field-label" %>
    <%= storage_form.password_field :app_key, value: nil, class: "field-input", placeholder: (@storage_connection.persisted? ? "Saved securely. Enter to replace." : nil) %>
  </div>
  <div>
    <%= storage_form.label :app_secret, "Dropbox App Secret", class: "field-label" %>
    <%= storage_form.password_field :app_secret, value: nil, class: "field-input", placeholder: (@storage_connection.persisted? ? "Saved securely. Enter to replace." : nil) %>
  </div>
  <div>
    <%= storage_form.label :refresh_token, "Dropbox Refresh Token", class: "field-label" %>
    <%= storage_form.password_field :refresh_token, value: nil, class: "field-input", placeholder: (@storage_connection.persisted? ? "Saved securely. Enter to replace." : nil) %>
  </div>
  <div>
    <%= storage_form.label :external_root_path, "Dropbox Folder Path", class: "field-label" %>
    <%= storage_form.text_field :external_root_path, class: "field-input", placeholder: "/Apps/Stockflow" %>
  </div>
</div>
<%= render "storage_provider_doc_link", provider_key: "dropbox" %>

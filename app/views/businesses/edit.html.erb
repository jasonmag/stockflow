<div class="mb-6 flex flex-wrap items-end justify-between gap-3">
  <div>
    <h1 class="page-title">Business Settings</h1>
    <p class="mt-1 text-sm text-slate-600">Manage store-level settings for <%= @business.name %>.</p>
  </div>
  <div class="flex flex-wrap gap-2">
    <%= link_to "Business Members", members_business_path, class: "btn btn-secondary" %>
    <%= link_to "Back to Dashboard", dashboard_path, class: "btn btn-secondary" %>
  </div>
</div>

<%= form_with model: @business, url: business_path, method: :patch, class: "card space-y-6" do |f| %>
  <% if @business.errors.any? %>
    <div class="flash flash-alert">
      <p class="font-semibold"><%= pluralize(@business.errors.count, "error") %> prevented these settings from being saved:</p>
      <ul class="mt-2 list-disc pl-5">
        <% @business.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid gap-4 md:grid-cols-2">
    <div>
      <%= f.label :contact_email, class: "field-label" %>
      <%= f.email_field :contact_email, class: "field-input" %>
    </div>

    <div>
      <%= f.label :contact_phone, class: "field-label" %>
      <%= f.text_field :contact_phone, class: "field-input" %>
    </div>

    <div class="md:col-span-2">
      <%= f.label :address, class: "field-label" %>
      <%= f.text_area :address, class: "field-input", rows: 3 %>
    </div>

    <div>
      <%= f.label :reminder_lead_days, class: "field-label" %>
      <%= f.number_field :reminder_lead_days, class: "field-input", min: 0 %>
    </div>

    <div>
      <%= f.label :currency, class: "field-label" %>
      <%= f.select :currency, options_for_select(@business.currency_options, @business.currency), {}, class: "field-input" %>
    </div>
  </div>

  <section class="rounded-lg border border-slate-200 p-4">
    <div class="flex flex-wrap items-start justify-between gap-3">
      <div>
        <h2 class="text-sm font-semibold text-slate-900">Purchase Funding Sources</h2>
        <p class="mt-1 text-xs text-slate-600">Manage funding source names and whether each one is cash or credit.</p>
      </div>
      <div class="flex flex-wrap gap-2">
        <%= link_to "View Funding Sources", purchase_funding_sources_path, class: "btn btn-secondary" %>
        <%= link_to "Add New Funding Source", new_purchase_funding_source_path, class: "btn btn-primary" %>
      </div>
    </div>

    <% if @purchase_funding_sources.any? %>
      <div class="mt-3 flex flex-wrap gap-2">
        <% @purchase_funding_sources.each do |source| %>
          <span class="rounded-full border border-slate-200 bg-slate-50 px-3 py-1 text-sm text-slate-700"><%= "#{source.name} (#{source.source_type.titleize})" %></span>
        <% end %>
      </div>
    <% else %>
      <p class="mt-3 text-sm text-slate-600">No funding sources yet. Add one to make it available in purchases.</p>
    <% end %>
  </section>

  <section class="rounded-lg border border-slate-200 p-4">
    <div class="flex flex-wrap items-start justify-between gap-3">
      <div>
        <h2 class="text-sm font-semibold text-slate-900">Products</h2>
        <p class="mt-1 text-xs text-slate-600">Manage product and inventory variant options used in purchasing and stock movement.</p>
      </div>
      <div class="flex flex-wrap gap-2">
        <%= link_to "View Products", products_path, class: "btn btn-secondary" %>
        <%= link_to "Add New Product Variant", new_product_path(return_to: edit_business_path), class: "btn btn-primary" %>
      </div>
    </div>

    <% if @products.any? %>
      <div class="mt-3 flex flex-wrap gap-2">
        <% @products.each do |product| %>
          <span class="rounded-full border border-slate-200 bg-slate-50 px-3 py-1 text-sm text-slate-700"><%= product.name %></span>
        <% end %>
      </div>
    <% else %>
      <p class="mt-3 text-sm text-slate-600">No products yet. Add one to make it available in purchases and inventory.</p>
    <% end %>
  </section>

  <section class="rounded-lg border border-slate-200 p-4">
    <div class="flex flex-wrap items-start justify-between gap-3">
      <div>
        <h2 class="text-sm font-semibold text-slate-900">Suppliers</h2>
        <p class="mt-1 text-xs text-slate-600">Manage supplier options used on the purchase form.</p>
      </div>
      <div class="flex flex-wrap gap-2">
        <%= link_to "View Suppliers", suppliers_path, class: "btn btn-secondary" %>
        <%= link_to "Add New Supplier", new_supplier_path(return_to: edit_business_path), class: "btn btn-primary" %>
      </div>
    </div>

    <% if @suppliers.any? %>
      <div class="mt-3 flex flex-wrap gap-2">
        <% @suppliers.each do |supplier| %>
          <span class="rounded-full border border-slate-200 bg-slate-50 px-3 py-1 text-sm text-slate-700"><%= supplier.name %></span>
        <% end %>
      </div>
    <% else %>
      <p class="mt-3 text-sm text-slate-600">No suppliers yet. Add one to make it available in purchases.</p>
    <% end %>
  </section>

  <section class="rounded-lg border border-slate-200 p-4">
    <div class="flex flex-wrap items-start justify-between gap-3">
      <div>
        <h2 class="text-sm font-semibold text-slate-900">Locations</h2>
        <p class="mt-1 text-xs text-slate-600">Manage receiving and storage locations used in inventory workflows.</p>
      </div>
      <div class="flex flex-wrap gap-2">
        <%= link_to "View Locations", locations_path, class: "btn btn-secondary" %>
        <%= link_to "Add New Location", new_location_path(return_to: edit_business_path), class: "btn btn-primary" %>
      </div>
    </div>

    <% if @locations.any? %>
      <div class="mt-3 flex flex-wrap gap-2">
        <% @locations.each do |location| %>
          <span class="rounded-full border border-slate-200 bg-slate-50 px-3 py-1 text-sm text-slate-700"><%= location.name %></span>
        <% end %>
      </div>
    <% else %>
      <p class="mt-3 text-sm text-slate-600">No locations yet. Add one to make it available in purchases and inventory.</p>
    <% end %>
  </section>

  <div class="flex flex-wrap gap-2">
    <%= f.submit "Save Settings", class: "btn btn-primary" %>
    <%= link_to "Cancel", dashboard_path, class: "btn btn-secondary" %>
  </div>
<% end %>

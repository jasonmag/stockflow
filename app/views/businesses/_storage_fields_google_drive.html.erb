<div class="grid gap-4 md:grid-cols-2">
  <div>
    <%= storage_form.label :client_id, "Google OAuth Client ID", class: "field-label" %>
    <%= storage_form.password_field :client_id, value: nil, class: "field-input", placeholder: (@storage_connection.persisted? ? "Saved securely. Enter to replace." : nil) %>
  </div>
  <div>
    <%= storage_form.label :client_secret, "Google OAuth Client Secret", class: "field-label" %>
    <%= storage_form.password_field :client_secret, value: nil, class: "field-input", placeholder: (@storage_connection.persisted? ? "Saved securely. Enter to replace." : nil) %>
  </div>
  <div>
    <%= storage_form.label :refresh_token, "Google Refresh Token", class: "field-label" %>
    <%= storage_form.password_field :refresh_token, value: nil, class: "field-input", placeholder: (@storage_connection.persisted? ? "Saved securely. Enter to replace." : nil) %>
  </div>
  <div>
    <%= storage_form.label :external_root_path, "Google Drive Folder URL or ID", class: "field-label" %>
    <%= storage_form.text_field :external_root_path, class: "field-input", placeholder: "https://drive.google.com/drive/folders/... or folder ID" %>
  </div>
</div>
<%= render "storage_provider_doc_link", provider_key: "google_drive" %>

<% documentation_url = BusinessStorageConnection::PROVIDER_DOCUMENTATION_URLS[provider_key] %>
<% provider_label = Business::FILE_STORAGE_PROVIDERS[provider_key] %>
<% if documentation_url.present? %>
  <p class="mt-3 text-xs text-slate-600">
    Need setup help?
    <%= link_to "Open the official #{provider_label} authentication guide",
      documentation_url,
      class: "font-medium text-sky-700 hover:text-sky-800",
      target: "_blank",
      rel: "noopener noreferrer" %>
  </p>
<% end %>

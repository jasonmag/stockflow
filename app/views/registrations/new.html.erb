<% content_for :title, "Register | Stockflow" %>

<section class="grid gap-6 lg:grid-cols-[minmax(0,1.05fr)_minmax(380px,0.95fr)] lg:items-stretch">
  <article class="relative overflow-hidden rounded-[2rem] border border-slate-200/70 bg-[linear-gradient(150deg,#0f172a_0%,#0e7490_46%,#f0fdfa_100%)] px-6 py-8 text-white shadow-[0_28px_70px_rgba(15,23,42,0.16)] md:px-8 md:py-10">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(255,255,255,0.18),transparent_30%),radial-gradient(circle_at_78%_18%,rgba(255,255,255,0.12),transparent_20%),radial-gradient(circle_at_bottom_right,rgba(8,47,73,0.35),transparent_30%)]"></div>

    <div class="relative">
      <p class="text-sm font-semibold uppercase tracking-[0.24em] text-cyan-100/85">New User Registration</p>
      <h1 class="mt-4 max-w-xl text-4xl font-semibold tracking-tight text-white md:text-5xl">Request access to the Stockflow workspace.</h1>
      <p class="mt-4 max-w-2xl text-base leading-7 text-cyan-50/90">
        Register a regular user account for your business operations team. After submission, a super admin reviews the request and assigns the appropriate business access.
      </p>

      <div class="mt-8 space-y-3">
        <div class="flex items-start gap-3 rounded-2xl border border-white/15 bg-white/10 px-4 py-4 backdrop-blur-sm">
          <span class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-white/20 text-sm font-semibold text-white">1</span>
          <div>
            <p class="text-sm font-semibold text-white">Submit your account details</p>
            <p class="mt-1 text-sm leading-6 text-cyan-50/80">Use your working email and create a password for future sign-in.</p>
          </div>
        </div>
        <div class="flex items-start gap-3 rounded-2xl border border-white/15 bg-white/10 px-4 py-4 backdrop-blur-sm">
          <span class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-white/20 text-sm font-semibold text-white">2</span>
          <div>
            <p class="text-sm font-semibold text-white">Wait for super admin approval</p>
            <p class="mt-1 text-sm leading-6 text-cyan-50/80">Your account stays pending until a super admin reviews and approves it.</p>
          </div>
        </div>
        <div class="flex items-start gap-3 rounded-2xl border border-white/15 bg-white/10 px-4 py-4 backdrop-blur-sm">
          <span class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-white/20 text-sm font-semibold text-white">3</span>
          <div>
            <p class="text-sm font-semibold text-white">Receive business assignment</p>
            <p class="mt-1 text-sm leading-6 text-cyan-50/80">Once assigned, you can sign in and work inside the correct business workspace.</p>
          </div>
        </div>
      </div>
    </div>
  </article>

  <article class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm md:p-8">
    <div class="mb-6">
      <p class="text-sm font-semibold uppercase tracking-[0.22em] text-cyan-700">Registration Form</p>
      <h2 class="mt-3 text-3xl font-semibold tracking-tight text-slate-900">Create your access request</h2>
      <p class="mt-3 text-sm leading-6 text-slate-600">
        This form creates a regular account request. You cannot sign in until a super admin approves the registration.
      </p>
    </div>

    <% if @user.errors.any? %>
      <p class="flash flash-alert mb-4"><%= @user.errors.full_messages.to_sentence %></p>
    <% end %>

    <%= form_with model: @user, url: registration_path, class: "space-y-5" do |form| %>
      <div>
        <%= form.label :email_address, "Email address", class: "field-label" %>
        <%= form.email_field :email_address,
          required: true,
          autocomplete: "username",
          placeholder: "name@company.com",
          class: "field-input" %>
      </div>

      <div>
        <%= form.label :password, "Password", class: "field-label" %>
        <%= form.password_field :password,
          required: true,
          autocomplete: "new-password",
          placeholder: "Create a password",
          class: "field-input" %>
      </div>

      <div>
        <%= form.label :password_confirmation, "Confirm password", class: "field-label" %>
        <%= form.password_field :password_confirmation,
          required: true,
          autocomplete: "new-password",
          placeholder: "Repeat your password",
          class: "field-input" %>
      </div>

      <div class="flex flex-wrap gap-3 pt-2">
        <%= form.submit "Submit registration", class: "btn btn-primary min-w-44" %>
        <%= link_to "Back to login", login_path, class: "btn btn-secondary" %>
      </div>
    <% end %>

    <div class="mt-6 rounded-2xl border border-dashed border-slate-200 bg-slate-50 px-4 py-4">
      <p class="text-sm font-medium text-slate-900">Already approved?</p>
      <p class="mt-2 text-sm leading-6 text-slate-600">
        Return to
        <%= link_to "user login", login_path, class: "font-medium text-cyan-700 hover:underline" %>
        and access your assigned workspace.
      </p>
    </div>
  </article>
</section>

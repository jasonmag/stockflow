<%= form_with model: purchase_funding_source, class: "card space-y-4" do |f| %>
  <%= hidden_field_tag :return_to, params[:return_to] if params[:return_to].present? %>

  <% if purchase_funding_source.errors.any? %>
    <div class="flash flash-alert">
      <p class="font-semibold"><%= pluralize(purchase_funding_source.errors.count, "error") %> prevented this funding source from being saved:</p>
      <ul class="mt-2 list-disc pl-5">
        <% purchase_funding_source.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid gap-4 md:grid-cols-2">
    <div>
      <%= f.label :name, class: "field-label" %>
      <%= f.text_field :name, class: "field-input", placeholder: "GCash" %>
    </div>

    <div>
      <%= f.label :source_type, "Option", class: "field-label" %>
      <%= f.select :source_type, PurchaseFundingSource.source_types.keys.map { |value| [value.titleize, value] }, {}, class: "field-input" %>
    </div>
  </div>

  <div class="flex flex-wrap gap-2">
    <%= f.submit class: "btn btn-primary" %>
    <%= link_to "Cancel", (@cancel_path || purchase_funding_sources_path), class: "btn btn-secondary" %>
  </div>
<% end %>

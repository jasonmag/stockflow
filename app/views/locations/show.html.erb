<div class="mb-6 flex flex-wrap items-end justify-between gap-3">
  <div>
    <h1 class="page-title"><%= @location.name %></h1>
    <p class="mt-1 text-sm text-slate-600">Location metadata used in stock movement validation.</p>
  </div>
  <div class="flex flex-wrap gap-2">
    <%= link_to "Edit", edit_location_path(@location), class: "btn btn-primary" %>
    <%= link_to "Back", locations_path, class: "btn btn-secondary" %>
  </div>
</div>

<section class="card">
  <dl>
    <dt class="kpi-label">Location Type</dt>
    <dd class="mt-1 text-sm text-slate-900"><%= @location.location_type.humanize %></dd>
  </dl>
</section>

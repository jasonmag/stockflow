<div class="mb-6 flex flex-wrap items-end justify-between gap-3">
  <div>
    <h1 class="page-title">Suppliers</h1>
    <p class="mt-1 text-sm text-slate-600">Manage suppliers used in purchase workflows.</p>
  </div>
  <%= link_to "New Supplier", new_supplier_path, class: "btn btn-primary" %>
</div>

<% if @suppliers.any? %>
  <div class="table-wrap">
    <table class="table-base">
      <thead>
        <tr>
          <th>Name</th>
          <th>Contact</th>
          <th>Email</th>
          <th>Phone</th>
          <th class="text-right">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @suppliers.each do |row| %>
          <tr>
            <td data-label="Name" class="font-medium text-slate-900"><%= link_to row.name, row, class: "hover:underline" %></td>
            <td data-label="Contact"><%= row.contact_name.presence || "-" %></td>
            <td data-label="Email"><%= row.contact_email.presence || "-" %></td>
            <td data-label="Phone"><%= row.contact_phone.presence || "-" %></td>
            <td data-label="Actions" class="text-right"><%= link_to "View", row, class: "btn btn-ghost" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <p class="empty-state">No suppliers yet. Add one to create purchase records.</p>
<% end %>
